{
  "name": "crea-ddf-effect-sdk",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "pnpm run typecheck && tsc --noCheck && cp -R src/db/migrations dist/db/migrations",
    "test": "pnpm run typecheck && vitest run",
    "check:metadata": "node scripts/check-metadata-parity.mjs",
    "prepare": "effect-language-service patch",
    "test:live": "node --env-file-if-exists=.env --import tsx --test src/live.integration.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/runMigrations.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.65",
    "@effect/sql-pg": "4.0.0-beta.65",
    "drizzle-kit": "1.0.0-rc.2",
    "drizzle-orm": "1.0.0-rc.2",
    "effect": "4.0.0-beta.65",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@effect/language-service": "0.85.1",
    "@effect/vitest": "4.0.0-beta.65",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.2",
    "@types/pg": "8.20.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  }
}

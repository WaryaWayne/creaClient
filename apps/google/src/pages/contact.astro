---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import ContactSection from "@/components/ContactSection.astro"
import { getSchemaEntityModel } from "@/lib/schema"
import { routes } from "@/lib/routes"
import type { BreadcrumbList, ContactPage, WithContext } from "schema-dts"

const title = "Contact Us | 2To6X"
const description =
  "Call or message 2To6X to fix your Google Ads and get more qualified leads."
const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const basePath = import.meta.env.BASE_URL
const { appSiteUrl, ids } = getSchemaEntityModel(siteUrl, basePath)
const pageUrl = routes.google.contact
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const turnstileSiteKey = import.meta.env.TURNSTILE_SITE_KEY

const schema: Array<WithContext<BreadcrumbList> | WithContext<ContactPage>> = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    name: "Contact breadcrumb",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Google", item: appSiteUrl },
      { "@type": "ListItem", position: 2, name: "Contact", item: canonicalUrl },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": `${canonicalUrl}#webpage`,
    url: canonicalUrl,
    name: title,
    description,
    isPartOf: {
      "@id": ids.appWebsite,
    },
    about: {
      "@id": ids.rootOrganization,
    },
    mainEntity: {
      "@id": ids.rootOrganization,
    },
    breadcrumb: {
      "@id": `${canonicalUrl}#breadcrumb`,
    },
  },
]
---

<Layout
  title={title}
  description={description}
  canonical={pageUrl}
  ogType="website"
  ogUrl={pageUrl}
  ogDescription={description}
  schema={schema}
  hideStickyBar
>
  <div class="mx-auto max-w-5xl px-4 pt-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />
  </div>

  <ContactSection headingTag="h1" turnstileSiteKey={turnstileSiteKey} />
</Layout>

---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import { FAQPage } from "@/components/FAQPage"
import { faqCategories } from "@/data/faq-page"
import { getSchemaEntityModel } from "@/lib/schema"
import { routes } from "@/lib/routes"
import type {
  BreadcrumbList,
  FAQPage as FAQPageSchema,
  Question,
  WithContext,
} from "schema-dts"

const title = "Google Ads FAQ | Pricing, Setup & Results Questions | 2To6X"
const description =
  "40 common questions about Google Ads, audits, pricing, keywords, ad copy, and results. Answered straight, no fluff."
const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const basePath = import.meta.env.BASE_URL
const { appSiteUrl, ids } = getSchemaEntityModel(siteUrl, basePath)
const pageUrl = routes.google.frequentlyAskedQuestions
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const questions: Question[] = faqCategories.flatMap((category) =>
  category.faqs.map((faq, index) => {
    const questionId = `${canonicalUrl}#${category.id}-question-${index + 1}`

    return {
      "@type": "Question",
      "@id": questionId,
      name: faq.q,
      acceptedAnswer: {
        "@type": "Answer",
        "@id": `${questionId}-answer`,
        name: `${faq.q} answer`,
        text: faq.a,
      },
    }
  })
)

const breadcrumbSchema: WithContext<BreadcrumbList> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  name: "Google Ads FAQ breadcrumb",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Google", item: appSiteUrl },
    { "@type": "ListItem", position: 2, name: "Google Ads FAQ", item: canonicalUrl },
  ],
}

const faqPageSchema: WithContext<FAQPageSchema> = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: title,
  headline: title,
  description,
  isPartOf: {
    "@id": ids.appWebsite,
  },
  breadcrumb: {
    "@id": `${canonicalUrl}#breadcrumb`,
  },
  mainEntity: questions,
}

const schema: Array<WithContext<BreadcrumbList> | WithContext<FAQPageSchema>> =
  [breadcrumbSchema, faqPageSchema]
---

<Layout
  title={title}
  description={description}
  canonical={pageUrl}
  ogType="website"
  schema={schema}
>
  <div class="mx-auto max-w-5xl px-4 pt-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />
  </div>
  <FAQPage client:load />
</Layout>

---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import Hero from "@/components/Hero.astro"
import Problem from "@/components/Problem.astro"
import BeforeAfter from "@/components/BeforeAfter.astro"
import Services from "@/components/Services.astro"
import HowItWorks from "@/components/HowItWorks.astro"
import SocialProof from "@/components/SocialProof.astro"
import OfferBlock from "@/components/OfferBlock.astro"
import FAQ from "@/components/FAQ.astro"
import FinalCTA from "@/components/FinalCTA.astro"

const pageUrl = "/_test"
---

<Layout canonical={pageUrl} ogUrl={pageUrl} robots="noindex,follow">
  <div class="mx-auto max-w-5xl px-4 pt-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />
  </div>
  <Hero />
  <Problem />
  <BeforeAfter />
  <Services />
  <HowItWorks />
  <SocialProof />
  <OfferBlock />
  <FAQ />
  <FinalCTA />
</Layout>

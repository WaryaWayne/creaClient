---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import { Card, CardContent } from "@workspace/ui/components/card"
import { PaymentCTA } from "@/components/PaymentCTA"
import Hero from "@/components/Hero.astro"
import ZarazViewContent from "@/components/ZarazViewContent.astro"
import SocialProof from "@/components/SocialProof.astro"
import FAQSection from "@/components/FAQSection.astro"
import FeatureGrid from "@/components/services/FeatureGrid.astro"
import FeaturesList from "@/components/services/FeaturesList.astro"
import PricingCard from "@/components/services/PricingCard.astro"
import { getSchemaEntityModel, sharedServiceArea } from "@/lib/schema"
import { routes } from "@/lib/routes"
import type { BreadcrumbList, Service, WebPage, WithContext } from "schema-dts"
import { productPaymentLinks } from "@/lib/payment-links"
import { X, Check } from "lucide-react"

const googleBusinessProfilePaymentLink =
  productPaymentLinks.googleBusinessProfilePaymentLink
const turnstileSiteKey = import.meta.env.TURNSTILE_SITE_KEY

const included = [
  {
    title: "Keyword-Optimized Description",
    desc: "We rewrite your business description to include the exact terms your customers search for, without sounding robotic.",
  },
  {
    title: "Services Listed & Described",
    desc: "Every service you offer, written and categorized properly so Google knows what you do and shows you for it.",
  },
  {
    title: "Products Added",
    desc: "Products with names, prices, and descriptions that show up directly in your profile before anyone even visits your site.",
  },
  {
    title: "Website & Booking Links",
    desc: "Direct links to your site, booking page, or any page that gets people to take action, not just your homepage.",
  },
  {
    title: "Category & Attribute Setup",
    desc: "The right primary and secondary categories make a massive difference in what searches you show up for.",
  },
  {
    title: "Photo Guidance",
    desc: "We tell you exactly which photos to add and how to label them so Google surfaces your profile higher.",
  },
]

const opportunityFeatures = [
  {
    title: "Show up in the Map Pack",
    desc: "The 3 businesses that appear above organic results on every local search. Free placement. Maximum visibility.",
  },
  {
    title: "Calls directly from Google",
    desc: "People call straight from your profile. No website visit required. No ad budget needed. Just a well-optimized profile.",
  },
  {
    title: "Zero cost per lead",
    descHtml: `Unlike Google Ads, these leads cost nothing per click. Set it up once and it keeps generating enquiries indefinitely. Pair it with <a href=\"${routes.google.services.AdsAudit}#pricing\" class=\"font-semibold text-primary underline underline-offset-2 hover:no-underline\">Google Ads Audit & Rewrite pricing</a> to cover both channels.`,
  },
]

const pricingItems = [
  "Optimized description",
  "Services listed",
  "Products added",
  "Links set up",
  "Category setup",
  "Photo guidance",
]

const faqs = [
  {
    q: "Do I need a Google Business Profile already?",
    a: "No. If you don't have one, we'll walk you through setting it up as part of the service. It takes 10 minutes on your end.",
  },
  {
    q: "How long before I start showing up in searches?",
    a: "Google usually indexes updates within 24–72 hours. Most clients start seeing impressions increase within the first week.",
  },
  {
    q: "Is this a monthly service?",
    aHtml: `No. This is a one-time optimization. We set it up right so it keeps working. If you want weekly updates to your paid campaigns, see <a href=\"${routes.google.services.WeeklyStrategy}#pricing\" class=\"font-semibold text-primary underline underline-offset-2 hover:no-underline\">weekly strategy pricing</a>.`,
  },
  {
    q: "What if I already have a Google Business Profile?",
    a: "Even better. We audit what you have and optimize everything: overwrite weak descriptions, add missing services, and fix categories.",
  },
  {
    q: "Does this work alongside Google Ads?",
    aHtml: `Yes, and it should. Paid ads bring traffic, GMB captures people who found you organically. Together they cover both channels. Start with <a href=\"${routes.google.services.AdsAudit}#features\" class=\"font-semibold text-primary underline underline-offset-2 hover:no-underline\">Google Ads Audit & Rewrite details</a>, then layer this in.`,
  },
]

const heroHeadline = `Free Leads Are Waiting.<br /><span class="text-primary">You're Not Capturing Them.</span>`
const heroSubheadline = [
  "Your Google Business Profile shows up free to everyone nearby searching for your service right now. Most businesses leave it half-empty - and hand those leads to competitors who did the work.",
  "$149 one-time. We set it up right. It works forever.",
]
const heroCtas = [
  {
    label: "Buy Profile Optimization for $149",
    target: "_blank" as const,
    href: googleBusinessProfilePaymentLink,
    variant: "default" as const,
    note: "One-time setup. No monthly fees. No contracts.",
    paymentOfferKey: "googleBusinessProfile" as const,
  },
]
const heroTrustPills = [
  "Free traffic from Google",
  "Zero cost per click",
  "$149 one-time",
  "Same-week delivery",
]

const title =
  "Google Business Profile Optimization | $149 Local SEO Setup | 2To6X"
const description =
  "We fully optimize your Google Business Profile so you show up for free to everyone nearby searching for your service. One-time $149 setup."

const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const basePath = import.meta.env.BASE_URL
const { appSiteUrl, ids } = getSchemaEntityModel(siteUrl, basePath)
const siteHomeUrl = appSiteUrl
const pageUrl = routes.google.services.GoogleMyBusiness
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const providerId = ids.googleProfessionalService
const serviceId = `${canonicalUrl}#service`
const areaServed = sharedServiceArea

const schema: Array<
  WithContext<Service> | WithContext<BreadcrumbList> | WithContext<WebPage>
> = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": serviceId,
    name: "Google Business Profile Optimization",
    description,
    url: canonicalUrl,
    serviceType: "Google Business Profile optimization service",
    areaServed,
    provider: {
      "@id": providerId,
    },
    offers: {
      "@type": "Offer",
      price: "149",
      priceCurrency: "CAD",
      availability: "https://schema.org/InStock",
      url: `${canonicalUrl}#pricing`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    name: "Google Business Profile Optimization breadcrumb",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Google",
        item: siteHomeUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Services",
        item: new URL(routes.google.services.Index, siteUrl).toString(),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Google Business Profile Optimization",
        item: canonicalUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${canonicalUrl}#webpage`,
    url: canonicalUrl,
    name: title,
    description,
    isPartOf: {
      "@id": `${siteHomeUrl}#website`,
    },
    mainEntity: {
      "@id": serviceId,
    },
    about: {
      "@id": serviceId,
    },
    breadcrumb: {
      "@id": `${canonicalUrl}#breadcrumb`,
    },
  },
]
---

<Layout
  title={title}
  description={description}
  canonical={pageUrl}
  ogType="website"
  schema={schema}
>
  <div class="mx-auto max-w-5xl px-4 pt-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />
  </div>

  <!-- HERO -->
  <Hero
    id="hero"
    tagline="Google Business Profile Optimization"
    headline={heroHeadline}
    subheadline={heroSubheadline}
    ctas={heroCtas}
    trustPills={heroTrustPills}
  />
  <ZarazViewContent contentKey="googleBusinessProfile" />

  <!-- THE OPPORTUNITY -->
  <FeatureGrid
    id="opportunity"
    eyebrow="The Opportunity"
    titleHtml={`Google Is Showing Your Business<br /><span class="text-primary">To People Right Now. For Free.</span>`}
    description={`When someone nearby searches "plumber near me" or "best HVAC Ottawa", Google shows a map pack with 3 local businesses. Those spots are free. The businesses in them did one thing: they optimized their profile.`}
    features={opportunityFeatures}
    cta={{
      eyebrow: "Profile Cleanup",
      heading: "Start the profile optimization.",
      subheadline:
        "We fill in the missing services, categories, descriptions, and conversion details.",
      buttonLabel: "Buy Profile Optimization for $149",
      href: googleBusinessProfilePaymentLink,
      target: "_blank",
      paymentOfferKey: "googleBusinessProfile",
    }}
  >
    <Card
      slot="after-grid"
      className="mb-12 gap-0 border-primary/30 bg-primary/20 py-0 text-center backdrop-blur-xs"
    >
      <CardContent className="px-6 py-6">
        <p class="text-lg font-bold text-foreground">
          You're already paying for ads. Why not own the free channel at the
          same time?
        </p>
        <p class="mt-1 text-sm text-foreground">
          A fully optimized GMB profile works 24/7 alongside your paid campaigns
          and captures leads that don't cost you a cent.
        </p>
      </CardContent>
    </Card>
  </FeatureGrid>

  <!-- WHAT'S INCLUDED -->
  <FeaturesList
    id="whats-included"
    eyebrow="What We Do"
    titleHtml={`Everything Your Profile<br /><span class="text-primary">Should Have But Doesn't.</span>`}
    items={included}
    cta={{
      eyebrow: "What's Included",
      heading: "Order the complete profile setup.",
      subheadline:
        "One flat payment covers the profile improvements that help local searchers choose you.",
      buttonLabel: "Buy Profile Optimization for $149",
      href: googleBusinessProfilePaymentLink,
      target: "_blank",
      paymentOfferKey: "googleBusinessProfile",
    }}
    ctaNote="One-time. Yours forever."
  />

  <!-- BEFORE / AFTER -->
  <section id="before-after" class="scroll-mt-25 px-4 py-20">
    <div class="mx-auto max-w-5xl">
      <div class="mb-14 text-center">
        <p
          class="mb-3 text-sm font-bold tracking-widest text-primary uppercase"
        >
          The Difference
        </p>
        <h2 class="text-4xl font-black md:text-5xl">
          Most Profiles Look Like This.<br /><span class="text-primary"
            >Yours Won't.</span
          >
        </h2>
      </div>
      <div class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-2">
        <!-- Before -->
        <Card
          className="gap-0 overflow-hidden border-destructive py-0 shadow-xl ring-0"
        >
          <div class="flex items-center gap-2 border-b border-destructive p-4">
            <span class="h-3 w-3 rounded-full bg-destructive"></span>
            <span
              class="text-xs font-black tracking-widest text-destructive uppercase"
              >Before: Typical Profile</span
            >
          </div>
          <CardContent className="space-y-3 px-6 py-6">
            {
              [
                "Description says: 'We offer plumbing services in Ottawa.'",
                "No services listed",
                "No products",
                "Only homepage URL linked",
                "Wrong primary category",
                "2 photos, both blurry",
              ].map((line) => (
                <p class="flex items-start gap-2 text-sm text-foreground">
                  <span class="font-bold text-destructive">
                    <X />
                  </span>
                  <span>{line}</span>
                </p>
              ))
            }
          </CardContent>
        </Card>
        <!-- After -->
        <Card
          className="gap-0 overflow-hidden border-primary/30 py-0 shadow-xl ring-0"
        >
          <div class="flex items-center gap-2 border-b border-primary p-4">
            <span class="h-3 w-3 rounded-full bg-primary"></span>
            <span
              class="text-xs font-black tracking-widest text-primary uppercase"
              >After: We Optimize It</span
            >
          </div>
          <CardContent className="space-y-3 px-6 py-6">
            {
              [
                "Keyword-rich 500-char description targeting local searches",
                "8 services listed with individual descriptions",
                "Products with prices shown directly on Google",
                "Booking link, website, and service-specific URLs",
                "Correct primary + secondary categories",
                "Photo guidance to maximize profile engagement",
              ].map((line) => (
                <p class="flex items-start gap-2 text-sm text-foreground">
                  <span class="font-bold text-primary">
                    <Check />
                  </span>
                  <span>{line}</span>
                </p>
              ))
            }
          </CardContent>
        </Card>
      </div>
      <div class="text-center">
        <PaymentCTA
          client:load
          variant={"default"}
          target="_blank"
          href={googleBusinessProfilePaymentLink}
          offerKey="googleBusinessProfile"
          turnstileSiteKey={turnstileSiteKey}
        >
          Buy Profile Optimization for $149
        </PaymentCTA>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <SocialProof
    eyebrow="Real Client Results"
    subheading="Neither Do Our Clients."
    cta={{
      eyebrow: "Next Step",
      heading: "Open the profile optimization checkout.",
      subheadline:
        "Use this package when the free local channel needs to be completed and cleaned up.",
      buttonLabel: "Buy Profile Optimization for $149",
      href: googleBusinessProfilePaymentLink,
      target: "_blank",
      paymentOfferKey: "googleBusinessProfile",
    }}
  />

  <!-- PRICING -->
  <section id="pricing" class="scroll-mt-25 px-4 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-3 text-sm font-bold tracking-widest text-primary uppercase">
        The Price
      </p>
      <h2 class="mb-10 text-4xl font-black md:text-5xl">
        One Payment.<br /><span class="text-primary"
          >Free Leads Forever After.</span
        >
      </h2>
      <p class="mb-8 text-sm text-foreground">
        Compare this with every offer on the{" "}
        <a
          href={routes.google.pricing + "#google-my-business-offer"}
          class="font-semibold text-primary underline underline-offset-2 hover:no-underline"
        >
          GBP offer details
        </a>
        .
      </p>
      <PricingCard
        variant="hero"
        itemLabel="Google Business Profile Optimization"
        price="$149"
        description="One-time. No monthly fee. No contracts."
        pills={pricingItems}
        ctaLabel="Buy Profile Optimization for $149"
        ctaHref={googleBusinessProfilePaymentLink}
        ctaTarget="_blank"
        paymentOfferKey="googleBusinessProfile"
        footnote="Delivered within 2 business days."
        cardClassName=""
        pillClassName="flex items-center gap-1.5 bg-background border border-border px-4 py-1.5"
      />
    </div>
  </section>

  <!-- FAQ -->
  <FAQSection
    id="faq"
    faqs={faqs}
    eyebrow="Questions"
    title="Straight Answers."
    variant="cards"
  >
    <div slot="footer">
      <PaymentCTA
        client:load
        variant={"default"}
        target="_blank"
        href={googleBusinessProfilePaymentLink}
        offerKey="googleBusinessProfile"
        turnstileSiteKey={turnstileSiteKey}
      >
        Buy Profile Optimization for $149
      </PaymentCTA>
    </div>
  </FAQSection>

  <!-- FINAL CTA -->
  <section id="final-cta" class="scroll-mt-25 px-4 py-12">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-3 text-sm font-bold tracking-widest text-primary uppercase">
        Free Leads Are There
      </p>
      <h2 class="mb-4 text-4xl font-black md:text-6xl">
        Someone Nearby Just Searched<br />
        <span class="text-primary">For What You Do.</span>
      </h2>
      <p class="mx-auto mb-10 max-w-xl text-lg text-foreground">
        Did they find you, or your competitor who took 30 minutes to fill out
        their profile? $149 fixes that today.
      </p>
      <PaymentCTA
        client:load
        variant={"default"}
        target="_blank"
        href={googleBusinessProfilePaymentLink}
        offerKey="googleBusinessProfile"
        turnstileSiteKey={turnstileSiteKey}
      >
        Buy Profile Optimization for $149
      </PaymentCTA>
      <p class="mt-4 text-xs text-foreground">
        One-time payment. Delivered in 2 business days.
      </p>
    </div>
  </section>
</Layout>

---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import {
  Item,
  ItemContent,
  ItemDescription,
  ItemMedia,
} from "@workspace/ui/components/item"
import { PaymentCTA } from "@/components/PaymentCTA"
import Hero from "@/components/Hero.astro"
import ZarazViewContent from "@/components/ZarazViewContent.astro"
import SocialProof from "@/components/SocialProof.astro"
import FAQSection from "@/components/FAQSection.astro"
import FeatureGrid from "@/components/services/FeatureGrid.astro"
import FeaturesList from "@/components/services/FeaturesList.astro"
import PricingCard from "@/components/services/PricingCard.astro"
import { getSchemaEntityModel, sharedServiceArea } from "@/lib/schema"
import { routes } from "@/lib/routes"
import type { BreadcrumbList, Service, WebPage, WithContext } from "schema-dts"
import { productPaymentLinks } from "@/lib/payment-links"

const Weekly4PlanPaymentLink =
  productPaymentLinks.weeklyStrategy4MeetingsPaymentLink
const turnstileSiteKey = import.meta.env.TURNSTILE_SITE_KEY

const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const basePath = import.meta.env.BASE_URL
const { appSiteUrl, ids } = getSchemaEntityModel(siteUrl, basePath)
const pageUrl = routes.google.services.WeeklyStrategy4Weeks
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const servicesUrl = new URL(routes.google.services.Index, siteUrl).toString()
const providerId = ids.googleProfessionalService
const serviceId = `${canonicalUrl}#service`
const areaServed = sharedServiceArea

const title = "4 Weekly Google Ads Check-Ins | $199 Optimization Sprint | 2To6X"
const description =
  "Monthly Google Ads check-ins with four weekly sessions. Live edits, tighter search terms, cleaner campaigns, and a one-time $199 payment discounted from $240 at $60 / week."

const whyThisBundle = [
  {
    title: "Enough time to reduce obvious inefficiency",
    desc: "Four consecutive weeks gives us room to clean search terms, add negatives, tighten bids, and confirm the account is moving in the right direction.",
  },
  {
    title: "Short enough to move fast",
    desc: "This is the right plan when you want a serious optimization sprint without committing to a full quarter or annual program.",
  },
  {
    title: "Discounted from the weekly base rate",
    desc: "At $199 one-time, the monthly plan is discounted from $240 at the $60 / week base rate.",
  },
]

const sessionBreakdown = [
  {
    title: "Week 1: Baseline + Priority Improvements",
    desc: "We review current performance, identify the least efficient areas, and make the first high-impact edits live in the account.",
  },
  {
    title: "Week 2: Search Term Cleanup",
    desc: "We mine the search terms, block unqualified traffic, and tighten the traffic you are paying for so spend starts getting cleaner.",
  },
  {
    title: "Week 3: Copy + Bid Improvements",
    desc: "We adjust ad copy, review CTR movement, test stronger hooks, and make bid changes based on what the first two weeks revealed.",
  },
  {
    title: "Week 4: Lock In the Next Moves",
    descHtml: `We review the month, document what improved, and decide whether to continue into the <a href="${routes.google.services.WeeklyStrategy12Weeks}#pricing" class="font-semibold text-primary underline underline-offset-2 hover:no-underline">3-month check-in plan</a> for deeper compounding.`,
  },
]

const roadmap = [
  {
    time: "Week 1",
    outcome:
      "Account triaged. Inefficient spend patterns identified. First live improvements made.",
  },
  {
    time: "Week 2",
    outcome:
      "Search terms cleaned up. Negative list improved. Click quality starts getting tighter.",
  },
  {
    time: "Week 3",
    outcome:
      "Ad copy and bid adjustments start affecting CTR, CPC, and lead quality.",
  },
  {
    time: "Week 4",
    outcome:
      "You leave with a cleaner account, a clearer baseline, and a next-step plan.",
  },
]

const plans = [
  {
    name: "Base Rate",
    price: "$60",
    per: "/ week",
    billing: "Weekly Ads Strategy base rate",
    description:
      "The rate used to price every monthly, 3-month, and 12-month plan.",
    href: productPaymentLinks.weeklyStrategySubscriptionPaymentLink,
    label: "Start Weekly",
    offerKey: "weeklyStrategy" as const,
    highlight: false,
  },
  {
    name: "Monthly Plan",
    price: "$199",
    per: "one-time",
    billing: "Discounted from $240 at $60 / week",
    description: "Best for a focused one-month optimization sprint.",
    href: Weekly4PlanPaymentLink,
    label: "Buy 4 Sessions",
    offerKey: "weeklyStrategy4Weeks" as const,
    highlight: true,
    badge: "Best Short Sprint",
  },
  {
    name: "3 Months",
    price: "$499",
    per: "one-time",
    billing: "Most popular",
    description:
      "Best if you want enough time for tests to mature and compound.",
    href: productPaymentLinks.weeklyStrategy12MeetingsPaymentLink,
    label: "Buy 12 Sessions",
    offerKey: "weeklyStrategy12Weeks" as const,
    highlight: false,
  },
]

const faqs = [
  {
    q: "Who is the monthly plan best for?",
    a: "Businesses that already know they want weekly optimization, but want to start with one disciplined month before deciding on a longer term plan.",
  },
  {
    q: "Is this enough time to fully turn an account around?",
    aHtml: `It is enough time to reduce a lot of inefficiency and establish momentum. If you want the full compounding effect, the <a href="${routes.google.services.WeeklyStrategy12Weeks}#results" class="font-semibold text-primary underline underline-offset-2 hover:no-underline">3-month plan</a> is usually the stronger fit.`,
  },
  {
    q: "Do sessions expire?",
    a: "No. If you need to reschedule a week, the session stays on your account and can be used later.",
  },
  {
    q: "Can I upgrade after the first month?",
    aHtml: `Yes. Most clients either start monthly or roll into the <a href="${routes.google.services.WeeklyStrategy12Weeks}#pricing" class="font-semibold text-primary underline underline-offset-2 hover:no-underline">3-month plan</a> once the first month proves out.`,
  },
]

const heroCtas = [
  {
    label: "Buy 4 Sessions for $199",
    target: "_blank" as const,
    href: Weekly4PlanPaymentLink,
    variant: "default" as const,
    note: "One payment. Four live weekly sessions. Discounted from $240 at $60 / week.",
    paymentOfferKey: "weeklyStrategy4Weeks" as const,
  },
]

const heroTrustPills = [
  "Monthly plan",
  "Discounted from $240 at $60 / week",
  "One-time payment",
  "Live edits included",
]

const schema: Array<
  WithContext<BreadcrumbList> | WithContext<WebPage> | WithContext<Service>
> = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    name: "Monthly Google Ads Check-Ins breadcrumb",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Google", item: appSiteUrl },
      { "@type": "ListItem", position: 2, name: "Services", item: servicesUrl },
      {
        "@type": "ListItem",
        position: 3,
        name: "Monthly Google Ads Check-Ins",
        item: canonicalUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${canonicalUrl}#webpage`,
    url: canonicalUrl,
    name: title,
    description,
    isPartOf: {
      "@id": ids.appWebsite,
    },
    mainEntity: {
      "@id": serviceId,
    },
    about: {
      "@id": serviceId,
    },
    breadcrumb: {
      "@id": `${canonicalUrl}#breadcrumb`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": serviceId,
    name: "Monthly Google Ads Check-Ins",
    description,
    url: canonicalUrl,
    serviceType: "Monthly Google Ads optimization check-in plan",
    areaServed,
    provider: {
      "@id": providerId,
    },
    offers: {
      "@type": "Offer",
      price: 199,
      priceCurrency: "CAD",
      availability: "https://schema.org/InStock",
      url: `${canonicalUrl}#pricing`,
    },
  },
]
---

<Layout
  title={title}
  description={description}
  canonical={canonicalUrl}
  ogType="website"
  schema={schema}
>
  <div class="mx-auto max-w-5xl px-4 pt-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />
  </div>

  <Hero
    id="hero"
    tagline="Monthly Google Ads Check-Ins"
    headline={`One Month.<br /><span class="text-primary">Four Sharp Weekly Improvements.</span>`}
    subheadline={[
      "This is the short, disciplined version of weekly optimization. Four live check-ins over four weeks to tighten traffic, improve copy, and reduce avoidable inefficiency fast.",
      "$199 one-time. Ideal after your audit or when you want a clean one-month optimization sprint.",
    ]}
    ctas={heroCtas}
    trustPills={heroTrustPills}
  />
  <ZarazViewContent contentKey="weeklyStrategy4Weeks" />

  <FeatureGrid
    id="why-this-plan"
    eyebrow="Why This Plan"
    titleHtml={`The Right Bundle If You Want<br /><span class="text-primary">A Serious Month of Progress.</span>`}
    description="Four weeks is enough to make meaningful live edits, review what changed, and tighten the account without dragging the process out."
    features={whyThisBundle}
    cta={{
      eyebrow: "4-Session Block",
      heading: "Buy the focused one-month sprint.",
      subheadline:
        "Use this option when you want four live weekly sessions paid upfront.",
      buttonLabel: "Buy 4 Sessions for $199",
      href: Weekly4PlanPaymentLink,
      target: "_blank",
      paymentOfferKey: "weeklyStrategy4Weeks",
    }}
  />

  <FeaturesList
    id="what-happens"
    eyebrow="Every Week"
    titleHtml={`What We Do Across<br /><span class="text-primary">All Four Sessions.</span>`}
    items={sessionBreakdown}
    gridClassName="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12"
    cta={{
      eyebrow: "Every Week",
      heading: "Order the 4-session block.",
      subheadline:
        "Four weekly sessions gives you a disciplined first month of account improvements.",
      buttonLabel: "Buy 4 Sessions for $199",
      href: Weekly4PlanPaymentLink,
      target: "_blank",
      paymentOfferKey: "weeklyStrategy4Weeks",
    }}
  />

  <section id="results" class="scroll-mt-25 px-4 py-20">
    <div class="mx-auto max-w-4xl">
      <div class="mb-14 text-center">
        <p
          class="mb-3 text-sm font-bold tracking-widest text-primary uppercase"
        >
          Month Roadmap
        </p>
        <h2 class="text-4xl font-black md:text-5xl">
          What Changes Over<br /><span class="text-primary">Four Weeks.</span>
        </h2>
      </div>
      <div class="space-y-4">
        {
          roadmap.map(({ time, outcome }) => (
            <Item
              variant="outline"
              className="items-center gap-6 bg-card shadow-xl"
            >
              <ItemMedia
                variant="default"
                className="w-28 shrink-0 justify-end"
              >
                <span class="text-sm font-black text-primary">{time}</span>
              </ItemMedia>
              <div class="h-8 w-px shrink-0 bg-primary/30" />
              <ItemContent>
                <ItemDescription className="line-clamp-none text-sm text-foreground">
                  {outcome}
                </ItemDescription>
              </ItemContent>
            </Item>
          ))
        }
      </div>
    </div>
  </section>

  <section id="pricing" class="scroll-mt-25 px-4 py-20">
    <div class="mx-auto max-w-5xl">
      <div class="mb-14 text-center">
        <p
          class="mb-3 text-sm font-bold tracking-widest text-primary uppercase"
        >
          Choose Your Pace
        </p>
        <h2 class="text-4xl font-black md:text-5xl">
          Start With Four Weeks<br /><span class="text-primary"
            >Or Go Longer.</span
          >
        </h2>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {
          plans.map((plan) => (
            <PricingCard
              variant="plan"
              planName={plan.name}
              price={plan.price}
              per={plan.per}
              planBilling={plan.billing}
              description={plan.description}
              ctaLabel={plan.label}
              ctaHref={plan.href}
              ctaTarget={plan.href.startsWith("http") ? "_blank" : "_self"}
              paymentOfferKey={plan.offerKey}
              highlight={plan.highlight}
              badge={plan.badge}
            />
          ))
        }
      </div>
      <p class="mt-4 text-center text-xs text-foreground">
        Want the general overview first? Start{" "}
        <a
          href={routes.google.services.AdsAudit}
          class="font-semibold text-primary underline underline-offset-2 hover:no-underline"
        >
          with an audit
        </a>
        .
      </p>
    </div>
  </section>

  <SocialProof
    eyebrow="Client Results"
    heading="The Fastest Gains"
    subheading="Come From Doing The Boring Weekly Work."
    cta={{
      eyebrow: "Next Step",
      heading: "Open the 4-session checkout.",
      subheadline:
        "Choose this when you want one focused month before committing longer.",
      buttonLabel: "Buy 4 Sessions for $199",
      href: Weekly4PlanPaymentLink,
      target: "_blank",
      paymentOfferKey: "weeklyStrategy4Weeks",
    }}
  />

  <FAQSection
    id="faq"
    faqs={faqs}
    eyebrow="Questions"
    title="Monthly Plan FAQ."
    variant="cards"
  >
    <div slot="footer">
      <PaymentCTA
        client:load
        variant={"default"}
        target="_blank"
        href={Weekly4PlanPaymentLink}
        offerKey="weeklyStrategy4Weeks"
        turnstileSiteKey={turnstileSiteKey}
      >
        Buy 4 Sessions for $199
      </PaymentCTA>
    </div>
  </FAQSection>
</Layout>

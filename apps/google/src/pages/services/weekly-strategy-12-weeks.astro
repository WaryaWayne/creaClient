---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import {
  Item,
  ItemContent,
  ItemDescription,
  ItemMedia,
} from "@workspace/ui/components/item"
import { PaymentCTA } from "@/components/PaymentCTA"
import Hero from "@/components/Hero.astro"
import ZarazViewContent from "@/components/ZarazViewContent.astro"
import SocialProof from "@/components/SocialProof.astro"
import FAQSection from "@/components/FAQSection.astro"
import FeatureGrid from "@/components/services/FeatureGrid.astro"
import FeaturesList from "@/components/services/FeaturesList.astro"
import PricingCard from "@/components/services/PricingCard.astro"
import { getSchemaEntityModel, sharedServiceArea } from "@/lib/schema"
import { routes } from "@/lib/routes"
import type { BreadcrumbList, Service, WebPage, WithContext } from "schema-dts"
import { productPaymentLinks } from "@/lib/payment-links"

const Weekly12PlanPaymentLink =
  productPaymentLinks.weeklyStrategy12MeetingsPaymentLink
const turnstileSiteKey = import.meta.env.TURNSTILE_SITE_KEY

const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const basePath = import.meta.env.BASE_URL
const { appSiteUrl, ids } = getSchemaEntityModel(siteUrl, basePath)
const pageUrl = routes.google.services.WeeklyStrategy12Weeks
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const servicesUrl = new URL(routes.google.services.Index, siteUrl).toString()
const providerId = ids.googleProfessionalService
const serviceId = `${canonicalUrl}#service`
const areaServed = sharedServiceArea

const title =
  "12 Weekly Google Ads Check-Ins | $499 Compounding Optimization Plan | 2To6X"
const description =
  "Three months of weekly Google Ads check-ins. Live edits, better tests, compounding account improvements, and one $499 payment discounted from $720 at $60 / week."

const whyThisBundle = [
  {
    title: "This is where results start compounding",
    desc: "Twelve weeks gives enough runway to test, learn, replace underperforming ideas, and keep doubling down on what starts working.",
  },
  {
    title: "Enough time for the algorithm to respond",
    desc: "Quality Score, CTR trends, search term cleanup, and bid signals need time. Three months gives those changes room to show up in the numbers.",
  },
  {
    title: "Best balance of cost and momentum",
    desc: "It is the most efficient middle ground: longer than a one-month sprint, less commitment than an annual plan, and discounted from $720 at the $60 / week base rate.",
  },
]

const sessionBreakdown = [
  {
    title: "Month 1: Clean Up the Account",
    desc: "We reduce inefficient spend, tighten targeting, stabilize search terms, and rebuild underperforming parts of the campaign into something worth scaling.",
  },
  {
    title: "Month 2: Test and Improve",
    desc: "Once the account is cleaner, we use the next four sessions to push copy tests, bid changes, and landing-page observations harder.",
  },
  {
    title: "Month 3: Compound the Winners",
    descHtml: `The final month is where the winning patterns start stacking. If you want a full-year operating rhythm after that, move into the <a href="${routes.google.services.WeeklyStrategy48Weeks}#pricing" class="font-semibold text-primary underline underline-offset-2 hover:no-underline">12-month plan</a>.`,
  },
]

const roadmap = [
  {
    time: "Month 1",
    outcome:
      "Inefficiencies identified and cleaned up. Search terms sharpened. Baseline performance gets more reliable.",
  },
  {
    time: "Month 2",
    outcome:
      "Tests start returning clearer winners. Messaging, bids, and structure become less reactive and more deliberate.",
  },
  {
    time: "Month 3",
    outcome:
      "The account has enough recent optimization history to make stronger decisions with less guesswork.",
  },
]

const plans = [
  {
    name: "Monthly",
    price: "$199",
    per: "one-time",
    billing: "Short sprint",
    description:
      "Best if you want to start with one month and evaluate from there.",
    href: productPaymentLinks.weeklyStrategy4MeetingsPaymentLink,
    label: "Buy 4 Sessions",
    offerKey: "weeklyStrategy4Weeks" as const,
    highlight: false,
  },
  {
    name: "3 Months",
    price: "$499",
    per: "one-time",
    billing: "Discounted from $720 at $60 / week",
    description:
      "Best for letting tests mature and improvements compound properly.",
    href: Weekly12PlanPaymentLink,
    label: "Buy 12 Sessions",
    offerKey: "weeklyStrategy12Weeks" as const,
    highlight: true,
    badge: "Most Popular",
  },
  {
    name: "12 Months",
    price: "$1,799",
    per: "one-time",
    billing: "Annual commitment",
    description:
      "Best if Google Ads is a serious long-term acquisition channel for you.",
    href: productPaymentLinks.weeklyStrategy48MeetingsPaymentLink,
    label: "Buy 48 Sessions",
    offerKey: "weeklyStrategy48Weeks" as const,
    highlight: false,
  },
]

const faqs = [
  {
    q: "Why is the 3-month plan the most popular?",
    a: "Because it gives enough time for weekly edits to actually compound. One month is useful. Three months is where accounts start feeling materially different.",
  },
  {
    q: "What kinds of businesses fit this plan best?",
    a: "Businesses already spending consistently on Google Ads and wanting a real optimization cadence instead of one-off advice.",
  },
  {
    q: "Can I still reschedule sessions?",
    a: "Yes. Sessions do not expire, so a missed week does not mean you lose the session.",
  },
  {
    q: "What happens after the 12 weeks end?",
    aHtml: `You can choose the monthly plan again or move into the <a href="${routes.google.services.WeeklyStrategy48Weeks}#pricing" class="font-semibold text-primary underline underline-offset-2 hover:no-underline">12-month plan</a> if you want a full-year operating rhythm.`,
  },
]

const heroCtas = [
  {
    label: "Buy 12 Sessions for $499",
    target: "_blank" as const,
    href: Weekly12PlanPaymentLink,
    variant: "default" as const,
    note: "Three months of weekly optimization. Discounted from $720 at $60 / week.",
    paymentOfferKey: "weeklyStrategy12Weeks" as const,
  },
]

const heroTrustPills = [
  "3-month plan",
  "Discounted from $720 at $60 / week",
  "Most popular plan",
  "Compounding improvements",
]

const schema: Array<
  WithContext<BreadcrumbList> | WithContext<WebPage> | WithContext<Service>
> = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    name: "3-Month Google Ads Check-Ins breadcrumb",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Google", item: appSiteUrl },
      { "@type": "ListItem", position: 2, name: "Services", item: servicesUrl },
      {
        "@type": "ListItem",
        position: 3,
        name: "3-Month Google Ads Check-Ins",
        item: canonicalUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${canonicalUrl}#webpage`,
    url: canonicalUrl,
    name: title,
    description,
    isPartOf: {
      "@id": ids.appWebsite,
    },
    mainEntity: {
      "@id": serviceId,
    },
    about: {
      "@id": serviceId,
    },
    breadcrumb: {
      "@id": `${canonicalUrl}#breadcrumb`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": serviceId,
    name: "3-Month Google Ads Check-Ins",
    description,
    url: canonicalUrl,
    serviceType: "3-month Google Ads optimization check-in plan",
    areaServed,
    provider: {
      "@id": providerId,
    },
    offers: {
      "@type": "Offer",
      price: 499,
      priceCurrency: "CAD",
      availability: "https://schema.org/InStock",
      url: `${canonicalUrl}#pricing`,
    },
  },
]
---

<Layout
  title={title}
  description={description}
  canonical={canonicalUrl}
  ogType="website"
  schema={schema}
>
  <div class="mx-auto max-w-5xl px-4 pt-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />
  </div>

  <Hero
    id="hero"
    tagline="3-Month Google Ads Check-Ins"
    headline={`Three Months.<br /><span class="text-primary">Enough Time To Compound.</span>`}
    subheadline={[
      "If one month is a sprint, twelve weeks is where optimization starts feeling structural. We get enough time to test, adjust, and keep stacking the winners.",
      "$499 one-time. Twelve live weekly sessions. Discounted from $720 at the $60 / week base rate.",
    ]}
    ctas={heroCtas}
    trustPills={heroTrustPills}
  />
  <ZarazViewContent contentKey="weeklyStrategy12Weeks" />

  <FeatureGrid
    id="why-this-plan"
    eyebrow="Why 3 Months"
    titleHtml={`This Is The Bundle Where<br /><span class="text-primary">Weekly Work Starts Paying Off.</span>`}
    description="Three months is long enough to clean up the account, run meaningful tests, and make decisions from patterns instead of guesses."
    features={whyThisBundle}
    cta={{
      eyebrow: "12-Session Block",
      heading: "Buy the 3-month session block.",
      subheadline:
        "Use this option when you want enough weekly sessions for tests and improvements to compound.",
      buttonLabel: "Buy 12 Sessions for $499",
      href: Weekly12PlanPaymentLink,
      target: "_blank",
      paymentOfferKey: "weeklyStrategy12Weeks",
    }}
  />

  <FeaturesList
    id="what-happens"
    eyebrow="Across Three Months"
    titleHtml={`How The 3-Month Plan<br /><span class="text-primary">Actually Breaks Down.</span>`}
    items={sessionBreakdown}
    gridClassName="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12"
    cta={{
      eyebrow: "Across Three Months",
      heading: "Order the 12-session block.",
      subheadline:
        "Twelve sessions gives the account enough runway for weekly improvements to build.",
      buttonLabel: "Buy 12 Sessions for $499",
      href: Weekly12PlanPaymentLink,
      target: "_blank",
      paymentOfferKey: "weeklyStrategy12Weeks",
    }}
  />

  <section id="results" class="scroll-mt-25 px-4 py-20">
    <div class="mx-auto max-w-4xl">
      <div class="mb-14 text-center">
        <p
          class="mb-3 text-sm font-bold tracking-widest text-primary uppercase"
        >
          90-Day View
        </p>
        <h2 class="text-4xl font-black md:text-5xl">
          What Three Months<br /><span class="text-primary"
            >Should Produce.</span
          >
        </h2>
      </div>
      <div class="space-y-4">
        {
          roadmap.map(({ time, outcome }) => (
            <Item
              variant="outline"
              className="items-center gap-6 bg-card shadow-xl"
            >
              <ItemMedia
                variant="default"
                className="w-28 shrink-0 justify-end"
              >
                <span class="text-sm font-black text-primary">{time}</span>
              </ItemMedia>
              <div class="h-8 w-px shrink-0 bg-primary/30" />
              <ItemContent>
                <ItemDescription className="line-clamp-none text-sm text-foreground">
                  {outcome}
                </ItemDescription>
              </ItemContent>
            </Item>
          ))
        }
      </div>
    </div>
  </section>

  <section id="pricing" class="scroll-mt-25 px-4 py-20">
    <div class="mx-auto max-w-5xl">
      <div class="mb-14 text-center">
        <p
          class="mb-3 text-sm font-bold tracking-widest text-primary uppercase"
        >
          Compare Bundles
        </p>
        <h2 class="text-4xl font-black md:text-5xl">
          Twelve Weeks Is The Sweet Spot.<br /><span class="text-primary"
            >Here’s Why.</span
          >
        </h2>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {
          plans.map((plan) => (
            <PricingCard
              variant="plan"
              planName={plan.name}
              price={plan.price}
              per={plan.per}
              planBilling={plan.billing}
              description={plan.description}
              ctaLabel={plan.label}
              ctaHref={plan.href}
              ctaTarget={plan.href.startsWith("http") ? "_blank" : "_self"}
              paymentOfferKey={plan.offerKey}
              highlight={plan.highlight}
              badge={plan.badge}
            />
          ))
        }
      </div>
    </div>
  </section>

  <SocialProof
    eyebrow="Client Results"
    heading="Three Months Of"
    subheading="Consistent Attention Beats Random Tweaks Every Time."
    cta={{
      eyebrow: "Next Step",
      heading: "Open the 12-session checkout.",
      subheadline:
        "Choose this when you want a serious 3-month optimization cadence.",
      buttonLabel: "Buy 12 Sessions for $499",
      href: Weekly12PlanPaymentLink,
      target: "_blank",
      paymentOfferKey: "weeklyStrategy12Weeks",
    }}
  />

  <FAQSection
    id="faq"
    faqs={faqs}
    eyebrow="Questions"
    title="3-Month Plan FAQ."
    variant="cards"
  >
    <div slot="footer">
      <PaymentCTA
        client:load
        variant={"default"}
        target="_blank"
        href={Weekly12PlanPaymentLink}
        offerKey="weeklyStrategy12Weeks"
        turnstileSiteKey={turnstileSiteKey}
      >
        Buy 12 Sessions for $499
      </PaymentCTA>
    </div>
  </FAQSection>
</Layout>

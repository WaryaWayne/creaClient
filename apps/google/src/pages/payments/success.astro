---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import { SuccessSetup } from "@/components/SuccessSetup"
import {
  getCompanyPhoneNumber,
  getCompanyPhoneNumberDisplay,
  getContactEmail,
  siteConfig,
} from "@/lib/site-config"
import { offerOrder } from "@/data/offers"
import type { ZarazOfferKey } from "@/lib/zaraz"
import * as Option from "effect/Option"
import * as Schema from "effect/Schema"
import * as SchemaGetter from "effect/SchemaGetter"
import { BadgeCheck } from "lucide-react"
import type { WebPage, WithContext } from "schema-dts"

export const prerender = false

const CONTACT_EMAIL = getContactEmail()
const COMPANY_PHONE_NUMBER = getCompanyPhoneNumber()
const COMPANY_PHONE_NUMBER_DISPLAY = getCompanyPhoneNumberDisplay()

const SearchParamString = Schema.Trim
const LowercaseSearchParamString = SearchParamString.pipe(
  Schema.decode({
    decode: SchemaGetter.toLowerCase<string>(),
    encode: SchemaGetter.toLowerCase<string>(),
  })
)
const StripeCheckoutSessionId = SearchParamString.pipe(
  Schema.check(Schema.isPattern(/^cs_(test|live)_[A-Za-z0-9]+$/))
)
const SuccessSetupSearchParamsSchema = Schema.fromURLSearchParams(
  Schema.Struct({
    service: Schema.optionalKey(LowercaseSearchParamString),
    offer: Schema.optionalKey(SearchParamString),
    session_id: Schema.optionalKey(SearchParamString),
  })
)
const ZarazSuccessSearchParamsSchema = Schema.fromURLSearchParams(
  Schema.Struct({
    service: Schema.optionalKey(LowercaseSearchParamString),
    offer: Schema.Literals(offerOrder),
    session_id: StripeCheckoutSessionId,
  })
)
const successSetupParamsOption = Schema.decodeUnknownOption(
  SuccessSetupSearchParamsSchema
)(Astro.url.searchParams)
const successSetupParams = Option.isSome(successSetupParamsOption)
  ? successSetupParamsOption.value
  : { service: "", offer: "", session_id: "" }
const zarazSuccessParamsOption = Schema.decodeUnknownOption(
  ZarazSuccessSearchParamsSchema
)(Astro.url.searchParams)
const subscriptionOfferKeys = new Set<ZarazOfferKey>(["weeklyStrategy"])
const zarazSuccessEvent = Option.isNone(zarazSuccessParamsOption)
  ? null
  : {
      eventKind: subscriptionOfferKeys.has(zarazSuccessParamsOption.value.offer)
        ? "subscription"
        : "purchase",
      offerKey: zarazSuccessParamsOption.value.offer,
      sessionId: zarazSuccessParamsOption.value.session_id,
    }
const initialService = successSetupParams.service?.includes("weekly")
  ? "weekly"
  : successSetupParams.service?.includes("business") ||
      successSetupParams.service?.includes("gmb") ||
      successSetupParams.offer === "googleBusinessProfile"
    ? "gmb"
    : successSetupParams.offer?.includes("weekly")
      ? "weekly"
      : "audit"

const pageTitle = "Payment Confirmed | Google Ads Access Setup | 2To6X"
const pageDescription =
  "Payment received. Choose your service and complete setup in 3–5 minutes so we can start right away."
const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const canonicalPath = Astro.url.pathname
const canonicalUrl = new URL(canonicalPath, siteUrl).toString()
const basePath = import.meta.env.BASE_URL
const siteHomeUrl = new URL(basePath, siteUrl).toString()

const pageSchema: WithContext<WebPage> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: pageTitle,
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    "@id": `${siteHomeUrl}#website`,
    url: siteHomeUrl,
    name: siteConfig.name,
  },
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalPath}
  ogType="website"
  robots="noindex,follow"
  includeOrganizationSchema={false}
  schema={pageSchema}
>
  <div class="mx-auto max-w-5xl px-4 pt-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />
  </div>

  <section class="relative overflow-hidden px-4 pt-24 pb-12">
    <div
      class="pointer-events-none absolute top-0 left-1/2 h-[280px] w-[620px] -translate-x-1/2 bg-primary opacity-5 blur-[120px]"
    >
    </div>

    <div class="relative mx-auto max-w-3xl text-center">
      <div
        class="mx-auto mb-5 flex h-20 w-20 items-center justify-center rounded-full border-2 border-primary bg-primary/10"
      >
        <BadgeCheck className="h-10 w-10 text-primary" />
      </div>
      <p
        class="mb-4 inline-block border border-primary/30 bg-primary/10 px-4 py-1.5 text-sm font-semibold tracking-widest text-primary uppercase"
      >
        Payment Confirmed
      </p>
      <h1 class="mb-4 text-4xl leading-tight font-black md:text-6xl">
        You're In.<br />
        <span class="text-primary">Let's Get You Set Up.</span>
      </h1>
      <p
        class="mx-auto max-w-2xl text-base leading-relaxed text-foreground md:text-lg"
      >
        Select your purchase, then follow the setup steps below. For the easiest
        setup, simply send us your account ID and we’ll handle the access
        request.
      </p>
      <div
        class="mt-5 flex flex-wrap items-center justify-center gap-3 text-sm"
      >
        <a
          href={`mailto:${CONTACT_EMAIL}`}
          class="border border-primary/40 bg-primary/10 px-4 py-2 font-semibold text-primary transition-colors hover:bg-primary/20"
        >
          Email us: {CONTACT_EMAIL}
        </a>
        {
          COMPANY_PHONE_NUMBER && (
            <a
              href={`tel:${COMPANY_PHONE_NUMBER}`}
              class="border border-border px-4 py-2 font-semibold text-foreground transition-colors hover:border-primary/40 hover:text-primary"
            >
              Call us: {COMPANY_PHONE_NUMBER_DISPLAY}
            </a>
          )
        }
      </div>
    </div>
  </section>

  <SuccessSetup
    client:load
    contactEmail={CONTACT_EMAIL}
    companyPhone={COMPANY_PHONE_NUMBER || undefined}
    companyPhoneDisplay={COMPANY_PHONE_NUMBER_DISPLAY || undefined}
    defaultService={initialService as "audit" | "gmb" | "weekly"}
  />

  {
    zarazSuccessEvent && (
      <span
        id="zaraz-success-event"
        data-event-kind={zarazSuccessEvent.eventKind}
        data-offer-key={zarazSuccessEvent.offerKey}
        data-session-id={zarazSuccessEvent.sessionId}
        hidden
      />
    )
  }

  <script>
    import {
      trackPurchase,
      trackSubscribe,
      type ZarazOfferKey,
    } from "@/lib/zaraz"

    const eventElement = document.getElementById("zaraz-success-event")
    const eventKind = eventElement?.dataset.eventKind as
      | "purchase"
      | "subscription"
      | undefined
    const offerKey = eventElement?.dataset.offerKey as ZarazOfferKey | undefined
    const sessionId = eventElement?.dataset.sessionId

    const markSuccessEventSent = (storageKey: string) => {
      try {
        if (window.sessionStorage.getItem(storageKey)) {
          return false
        }

        window.sessionStorage.setItem(storageKey, "sent")
      } catch {
        return true
      }

      return true
    }

    if (eventKind && offerKey && sessionId) {
      const storageKey = `zaraz_success_${eventKind}_${offerKey}_${sessionId}`

      if (markSuccessEventSent(storageKey)) {
        if (eventKind === "subscription") {
          trackSubscribe(offerKey, sessionId)
        } else {
          trackPurchase(offerKey, sessionId)
        }
      }
    }
  </script>
</Layout>

---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import {
  Empty,
  EmptyTitle,
  EmptyDescription,
  EmptyHeader,
  EmptyMedia,
} from "@workspace/ui/components/Empty"
import { serviceTypes } from "@/data/service-types"
import { Check, Search } from "lucide-react"
import type { WebPage, WithContext } from "schema-dts"
import { routes } from "@/lib/routes"

const pageTitle = "404: Page Not Found | 2To6X"
const pageDescription =
  "This page doesn't exist. Navigate back to improve your Google Ads."
const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const pageUrl = `${routes.google.home}/404`
const canonicalUrl = new URL(pageUrl, siteUrl).toString()

const webPageSchema: WithContext<WebPage> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  ogUrl={canonicalUrl}
  ogDescription={pageDescription}
  robots="noindex,follow"
  includeOrganizationSchema={false}
  schema={webPageSchema}
>
  <div class="mx-auto max-w-5xl px-4 pt-12 pb-24">
    <PathBreadcrumb className="mb-6" location={Astro.url.pathname} />

    <!-- ── Error hero ────────────────────────────────────────────── -->
    <Empty className="py-10">
      <EmptyHeader>
        <EmptyMedia variant="icon">
          <Search className="text-primary" />
        </EmptyMedia>

        <p
          class="font-heading text-[7rem] leading-none font-black tracking-tight text-primary/20 select-none"
        >
          404
        </p>

        <EmptyTitle>Lost in the Funnel</EmptyTitle>

        <EmptyDescription>
          This page doesn't exist, but your next lead does.<br />
          Pick where you actually need to go:
        </EmptyDescription>
      </EmptyHeader>
    </Empty>

    <!-- ── Mosaic navigation ─────────────────────────────────────── -->
    <!--
      Layout (md 4-col grid):
      Row 1: [ Home ×2 ]  [ FAQ ]  [ Contact ]
      Row 2: [ Home ×2 ]  [ Services overview ×2 ]
      Row 3: [ Audit ×2 ] [ GMB ] [ Weekly ]
      Row 4: [ Industries ×4 ]
    -->
    <div class="mt-8 grid grid-cols-1 gap-3 md:grid-cols-4">
      <!-- HOME — featured 2 cols × 2 rows ────────────────────────── -->
      <a
        href={import.meta.env.BASE_URL}
        class="group flex min-h-[220px] flex-col justify-between border-2 border-primary/40 bg-primary/5 p-8 backdrop-blur-xs transition-colors hover:border-primary hover:bg-primary/10 md:col-span-2 md:row-span-2"
      >
        <div>
          <p
            class="mb-3 text-xs font-bold tracking-widest text-primary uppercase"
          >
            Start Here
          </p>
          <h2
            class="text-3xl font-black text-foreground transition-colors group-hover:text-primary"
          >
            Home
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-foreground/70">
            Everything about 2To6X: how we improve underperforming Google Ads,
            what's included, real before/after ad examples, and pricing. The
            full picture on one page.
          </p>
          <ul class="mt-5 space-y-1.5">
            {
              [
                "How it works",
                "Before / after ad examples",
                "Pricing & offers",
                "Client results",
              ].map((item) => (
                <li class="flex items-center gap-2 text-xs text-foreground/60">
                  <span class="font-black text-primary"><Check /></span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
        <div
          class="mt-6 flex items-center justify-between border-t border-primary/20 pt-4"
        >
          <span class="text-xs font-bold tracking-widest text-primary uppercase"
            >2to6x.com</span
          >
          <span
            class="font-black text-primary transition-transform group-hover:translate-x-1"
            >→</span
          >
        </div>
      </a>

      <!-- FAQ ─────────────────────────────────────────────────────── -->
      <a
        href={routes.google.frequentlyAskedQuestions}
        class="group flex flex-col justify-between border border-border bg-background p-6 transition-colors hover:border-primary/40 hover:bg-primary/5 hover:backdrop-blur-sm"
      >
        <div>
          <p
            class="mb-2 text-xs font-bold tracking-widest text-primary uppercase"
          >
            Questions
          </p>
          <h2
            class="text-xl font-black text-foreground transition-colors group-hover:text-primary"
          >
            FAQ
          </h2>
          <p class="mt-1.5 text-xs leading-relaxed text-foreground/70">
            Every objection about audits, results, and how we work, answered
            plainly.
          </p>
        </div>
        <div
          class="mt-4 flex items-center justify-between border-t border-border pt-3"
        >
          <span class="text-xs text-foreground/50">Common questions</span>
          <span
            class="font-black text-primary transition-transform group-hover:translate-x-1"
            >→</span
          >
        </div>
      </a>

      <!-- CONTACT ─────────────────────────────────────────────────── -->
      <a
        href={routes.google.contact}
        class="group flex flex-col justify-between border border-border bg-background p-6 transition-colors hover:border-primary/40 hover:bg-primary/5 hover:backdrop-blur-sm"
      >
        <div>
          <p
            class="mb-2 text-xs font-bold tracking-widest text-primary uppercase"
          >
            Talk to Us
          </p>
          <h2
            class="text-xl font-black text-foreground transition-colors group-hover:text-primary"
          >
            Contact
          </h2>
          <p class="mt-1.5 text-xs leading-relaxed text-foreground/70">
            Call or drop a message. We respond within a few hours on business
            days. Real people, not a call centre.
          </p>
        </div>
        <div
          class="mt-4 flex items-center justify-between border-t border-border pt-3"
        >
          <span class="text-xs text-foreground/50">2hr response</span>
          <span
            class="font-black text-primary transition-transform group-hover:translate-x-1"
            >→</span
          >
        </div>
      </a>

      <!-- SERVICES OVERVIEW — spans 2 cols (fills row 2 beside Home) -->
      <a
        href={routes.google.services.Index}
        class="group flex flex-col justify-between border border-border bg-background p-6 transition-colors hover:border-primary/40 hover:bg-primary/5 hover:backdrop-blur-sm md:col-span-2"
      >
        <div>
          <p
            class="mb-2 text-xs font-bold tracking-widest text-primary uppercase"
          >
            All Services
          </p>
          <h2
            class="text-xl font-black text-foreground transition-colors group-hover:text-primary"
          >
            Browse Services
          </h2>
          <p class="mt-1.5 text-sm leading-relaxed text-foreground/70">
            Six focused offers to get more leads from Google: one-time
            improvements, free local traffic, and weekly optimization bundles.
          </p>
        </div>
        <div
          class="mt-4 flex items-center justify-between border-t border-border pt-3"
        >
          <span class="text-xs text-foreground/50">Starting for $149</span>
          <span
            class="font-black text-primary transition-transform group-hover:translate-x-1"
            >→</span
          >
        </div>
      </a>

      <!-- ADS AUDIT — most popular, 2 cols ────────────────────────── -->
      <a
        href={routes.google.services.AdsAudit}
        class="group flex flex-col justify-between border border-primary/30 bg-primary/5 p-6 backdrop-blur-xs transition-colors hover:border-primary/60 hover:bg-primary/10 md:col-span-2"
      >
        <div>
          <div class="mb-2 flex items-center gap-2">
            <p class="text-xs font-bold tracking-widest text-primary uppercase">
              Most Popular
            </p>
            <span
              class="border border-primary/30 bg-primary/10 px-2 py-0.5 text-xs font-bold text-primary"
              >Full-scope</span
            >
          </div>
          <h2
            class="text-xl font-black text-foreground transition-colors group-hover:text-primary"
          >
            Ads Audit & Rewrite
          </h2>
          <p class="mt-1.5 text-sm leading-relaxed text-foreground/70">
            We go through every campaign, keyword, and ad to find inefficient
            spend and rewrite your copy from scratch. Delivered the same
            business day.
          </p>
        </div>
        <div
          class="mt-4 flex items-center justify-between border-t border-primary/20 pt-3"
        >
          <span class="text-sm font-black text-foreground"
            >for $300 <span class="text-xs font-normal text-foreground/60"
              >flat rate</span
            ></span
          >
          <span
            class="font-black text-primary transition-transform group-hover:translate-x-1"
            >→</span
          >
        </div>
      </a>

      <!-- GMB ─────────────────────────────────────────────────────── -->
      <a
        href={routes.google.services.GoogleMyBusiness}
        class="group flex flex-col justify-between border border-border bg-background p-6 transition-colors hover:border-primary/40 hover:bg-primary/5 hover:backdrop-blur-sm"
      >
        <div>
          <p
            class="mb-2 text-xs font-bold tracking-widest text-primary uppercase"
          >
            Local SEO
          </p>
          <h2
            class="text-xl font-black text-foreground transition-colors group-hover:text-primary"
          >
            Google Business Profile
          </h2>
          <p class="mt-1.5 text-xs leading-relaxed text-foreground/70">
            One-time profile optimization. Free leads from Google local search,
            forever.
          </p>
        </div>
        <div
          class="mt-4 flex items-center justify-between border-t border-border pt-3"
        >
          <span class="text-sm font-black text-foreground"
            >for $149 <span class="text-xs font-normal text-foreground/60"
              >one-time</span
            ></span
          >
          <span
            class="font-black text-primary transition-transform group-hover:translate-x-1"
            >→</span
          >
        </div>
      </a>

      <!-- WEEKLY STRATEGY ─────────────────────────────────────────── -->
      <a
        href={routes.google.services.WeeklyStrategy}
        class="group flex flex-col justify-between border border-border bg-background p-6 transition-colors hover:border-primary/40 hover:bg-primary/5 hover:backdrop-blur-sm"
      >
        <div>
          <p
            class="mb-2 text-xs font-bold tracking-widest text-primary uppercase"
          >
            Ongoing
          </p>
          <h2
            class="text-xl font-black text-foreground transition-colors group-hover:text-primary"
          >
            Weekly Check-Ins
          </h2>
          <p class="mt-1.5 text-xs leading-relaxed text-foreground/70">
            Live weekly optimization calls with live in-account edits. Compound
            results over time.
          </p>
        </div>
        <div
          class="mt-4 flex items-center justify-between border-t border-border pt-3"
        >
          <span class="text-sm font-black text-foreground"
            >for $60 <span class="text-xs font-normal text-foreground/60"
              >/ week</span
            ></span
          >
          <span
            class="font-black text-primary transition-transform group-hover:translate-x-1"
            >→</span
          >
        </div>
      </a>

      <!-- INDUSTRIES — full width ─────────────────────────────────── -->
      <div class="border border-border bg-background p-6 md:col-span-4">
        <div class="mb-5">
          <p
            class="mb-1 text-xs font-bold tracking-widest text-primary uppercase"
          >
            By Industry
          </p>
          <p class="text-lg font-black text-foreground">
            See What Underperforming vs. Improved Looks Like{" "}
            <span class="text-primary">for Your Trade</span>
          </p>
          <p class="mt-1 text-xs leading-relaxed text-foreground/60">
            Real ad examples, common improvement areas, and conversion stats for
            every major emergency service industry.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          {
            serviceTypes.map((s) => (
              <a
                href={`${routes.google.industry.Index}/${s.slug}`}
                class="flex items-center gap-1.5 border border-border bg-background px-3 py-2 text-xs font-bold text-foreground transition-colors hover:border-primary/40 hover:bg-primary/5 hover:text-primary hover:backdrop-blur-sm"
              >
                <span>{s.name}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Layout>

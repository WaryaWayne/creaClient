---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import { policyLinks } from "@/lib/policies"
import type { BreadcrumbList, WebPage, WithContext } from "schema-dts"
import { routes } from "@/lib/routes"
import { getContactEmail, siteConfig } from "@/lib/site-config"

const lastUpdated = "January 15, 2025"
const effectiveDate = "January 15, 2025"
const companyName = siteConfig.legalName
const contactEmail = getContactEmail()
const websiteUrl = siteConfig.rootUrl

const policyName = "Cookie Policy"
const pageTitle = `${policyName} | ${siteConfig.name} | 2To6X`
const pageDescription = `Cookie Policy for ${siteConfig.name}. Learn what cookies we use, why, and how to control them.`
const pageUrl = routes.google.policies.Cookies
const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const policiesUrl = new URL(routes.google.policies.Index, siteUrl).toString()
const trackingOptOutUrl = routes.google.policies.TrackingOptOut

const webPageSchema: WithContext<WebPage> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  breadcrumb: {
    "@id": `${canonicalUrl}#breadcrumb`,
  },
}

const breadcrumbSchema: WithContext<BreadcrumbList> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  name: `${policyName} breadcrumb`,
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Google",
      item: new URL(routes.google.home, siteUrl).toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Policies",
      item: policiesUrl,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: policyName,
      item: canonicalUrl,
    },
  ],
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogType="article"
  ogUrl={pageUrl}
  ogDescription={pageDescription}
  canonical={pageUrl}
  schema={[webPageSchema, breadcrumbSchema]}
>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />

    <!-- Header -->
    <div class="mb-12 border-b border-border pb-10">
      <div
        class="mb-4 inline-block border border-primary/30 bg-primary/10 px-4 py-1.5 text-xs font-semibold tracking-widest text-primary uppercase"
      >
        Legal
      </div>
      <h1 class="mb-4 text-4xl font-black tracking-tight md:text-5xl">
        Cookie Policy
      </h1>
      <div class="flex flex-wrap gap-6 text-sm text-foreground/60">
        <span>Last Updated: {lastUpdated}</span>
        <span>Effective Date: {effectiveDate}</span>
      </div>
    </div>

    <!-- Intro -->
    <div
      class="mb-10 border border-primary/20 bg-primary/5 p-6 shadow-xl backdrop-blur-md"
    >
      <p class="text-sm leading-relaxed text-foreground">
        <strong class="text-foreground">Plain-English Summary:</strong> Our website
        uses cookies (small text files stored on your device) to make the site work,
        measure page visits and site performance, measure selected conversion events,
        and show relevant ads. You can disable our custom ad and conversion event
        tracking for this browser from our <a
          href={trackingOptOutUrl}
          class="text-primary underline underline-offset-2"
          >Ad Tracking Opt-Out page</a
        >. Basic page-visit measurement and the core cookies needed for the site
        to function may still operate. You can also control or delete cookies
        through your browser settings. Questions? Email <a
          href={`mailto:${contactEmail}`}
          class="text-primary underline underline-offset-2">{contactEmail}</a
        >.
      </p>
    </div>

    <div class="space-y-10 text-foreground">
      <!-- 1. What Are Cookies -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          1. What Are Cookies?
        </h2>
        <p class="mb-4 leading-relaxed">
          Cookies are small text files that are placed on your computer, phone,
          or other device when you visit a website. They are widely used to make
          websites work efficiently, to remember your preferences, and to
          provide information to website owners.
        </p>
        <p class="mb-4 leading-relaxed">
          Cookies are not viruses or malware. They cannot execute programs or
          install software on your device. A cookie can only be read by the
          website that created it.
        </p>
        <p class="leading-relaxed">
          In addition to cookies, we may also use similar tracking technologies
          such as:
        </p>
        <ul class="mt-3 space-y-2 text-sm">
          {
            [
              {
                name: "Web Beacons / Pixels",
                desc: "Invisible 1x1 images embedded in web pages or emails that signal when content is loaded or an email is opened.",
              },
              {
                name: "Local Storage",
                desc: "Similar to cookies but stored directly in your browser and not sent with every HTTP request.",
              },
              {
                name: "Session Storage",
                desc: "Temporary storage that is cleared when you close your browser tab.",
              },
              {
                name: "Fingerprinting",
                desc: "We do not use device fingerprinting.",
              },
            ].map(({ name, desc }) => (
              <li class="border border-border bg-card p-3 shadow-xl">
                <span class="font-bold text-foreground">{name}: </span>
                <span class="text-foreground/80">{desc}</span>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- 2. Types of Cookies -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          2. Types of Cookies We Use
        </h2>

        <!-- Essential -->
        <div class="mb-6">
          <div class="mb-3 flex items-center gap-3">
            <span class="inline-block h-3 w-3 bg-primary"></span>
            <h3 class="text-lg font-black text-foreground">
              Essential Cookies
            </h3>
            <span
              class="border border-primary/30 bg-primary/10 px-2 py-0.5 text-xs font-bold text-primary"
              >Always Active</span
            >
          </div>
          <p class="mb-4 text-sm leading-relaxed text-foreground/80">
            These cookies are strictly necessary for the website to function.
            They cannot be switched off. They are typically set in response to
            actions you take on the site, such as submitting a form. You can set
            your browser to block or alert you about these cookies, but some
            parts of the site will then not work.
          </p>
          <div class="overflow-x-auto">
            <table
              class="w-full border border-border bg-card text-sm shadow-2xl"
            >
              <thead>
                <tr class="border-b border-border bg-background/80">
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Cookie</th
                  >
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Purpose</th
                  >
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Duration</th
                  >
                </tr>
              </thead>
              <tbody>
                {
                  [
                    {
                      name: "__cf_bm",
                      purpose:
                        "Cloudflare bot management: identifies automated bots vs. human traffic",
                      duration: "30 minutes",
                    },
                    {
                      name: "XSRF-TOKEN",
                      purpose:
                        "Security token to prevent cross-site request forgery attacks",
                      duration: "Session",
                    },
                    {
                      name: "session",
                      purpose: "Maintains your session state across page loads",
                      duration: "Session",
                    },
                  ].map(({ name, purpose, duration }) => (
                    <tr class="border-b border-border">
                      <td class="px-4 py-3 font-mono text-xs text-primary">
                        {name}
                      </td>
                      <td class="px-4 py-3 text-foreground/80">{purpose}</td>
                      <td class="px-4 py-3 text-foreground/60">{duration}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>

        <!-- Analytics -->
        <div class="mb-6">
          <div class="mb-3 flex items-center gap-3">
            <span class="inline-block h-3 w-3 bg-foreground/40"></span>
            <h3 class="text-lg font-black text-foreground">
              Analytics Cookies
            </h3>
            <span
              class="border border-border px-2 py-0.5 text-xs font-bold text-foreground/60"
              >Basic Measurement</span
            >
          </div>
          <p class="mb-4 text-sm leading-relaxed text-foreground/80">
            These cookies allow us to count visits and traffic sources so we can
            measure and improve the performance of our website. They help us
            know which pages are the most and least popular and see how visitors
            move around the site. This basic page-visit measurement may still
            operate even if custom ad event tracking is disabled for this
            browser.
          </p>
          <div class="overflow-x-auto">
            <table
              class="w-full border border-border bg-card text-sm shadow-2xl"
            >
              <thead>
                <tr class="border-b border-border bg-background/80">
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Cookie</th
                  >
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Provider</th
                  >
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Purpose</th
                  >
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Duration</th
                  >
                </tr>
              </thead>
              <tbody>
                {
                  [
                    {
                      name: "_ga",
                      provider: "Google Analytics",
                      purpose:
                        "Distinguishes unique users by assigning a randomly generated number",
                      duration: "2 years",
                    },
                    {
                      name: "_ga_*",
                      provider: "Google Analytics",
                      purpose: "Persists session state in Google Analytics 4",
                      duration: "2 years",
                    },
                    {
                      name: "_gid",
                      provider: "Google Analytics",
                      purpose:
                        "Distinguishes users by storing and updating a unique value for each page visited",
                      duration: "24 hours",
                    },
                    {
                      name: "_gat",
                      provider: "Google Analytics",
                      purpose:
                        "Throttles request rate (limits data collection on high-traffic sites)",
                      duration: "1 minute",
                    },
                  ].map(({ name, provider, purpose, duration }) => (
                    <tr class="border-b border-border">
                      <td class="px-4 py-3 font-mono text-xs text-primary">
                        {name}
                      </td>
                      <td class="px-4 py-3 text-foreground/60">{provider}</td>
                      <td class="px-4 py-3 text-foreground/80">{purpose}</td>
                      <td class="px-4 py-3 text-foreground/60">{duration}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>

        <!-- Marketing -->
        <div class="mb-6">
          <div class="mb-3 flex items-center gap-3">
            <span class="inline-block h-3 w-3 bg-foreground/40"></span>
            <h3 class="text-lg font-black text-foreground">
              Marketing & Advertising Cookies
            </h3>
            <span
              class="border border-border px-2 py-0.5 text-xs font-bold text-foreground/60"
              >Advertising Measurement</span
            >
          </div>
          <p class="mb-4 text-sm leading-relaxed text-foreground/80">
            These cookies are set through our site by our advertising partners.
            They may be used to measure ads, understand conversions, and show
            more relevant ads. Our site-specific opt-out controls the custom ad
            and conversion events we send from this browser. Browser settings,
            content blockers, and platform privacy settings may also limit these
            technologies.
          </p>
          <div class="overflow-x-auto">
            <table
              class="w-full border border-border bg-card text-sm shadow-2xl"
            >
              <thead>
                <tr class="border-b border-border bg-background/80">
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Cookie</th
                  >
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Provider</th
                  >
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Purpose</th
                  >
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Duration</th
                  >
                </tr>
              </thead>
              <tbody>
                {
                  [
                    {
                      name: "_gcl_au",
                      provider: "Google Ads",
                      purpose:
                        "Google Ads conversion tracking: stores and tracks conversions",
                      duration: "90 days",
                    },
                    {
                      name: "_gcl_aw",
                      provider: "Google Ads",
                      purpose:
                        "Conversion tracking: captures click information from paid campaigns",
                      duration: "90 days",
                    },
                    {
                      name: "IDE",
                      provider: "Google DoubleClick",
                      purpose:
                        "Used for targeting and retargeting; registers and reports user actions after viewing/clicking an ad",
                      duration: "1 year",
                    },
                    {
                      name: "NID",
                      provider: "Google",
                      purpose:
                        "Registers a unique ID to show Google ads in Google services for signed-out users",
                      duration: "6 months",
                    },
                    {
                      name: "_fbp",
                      provider: "Meta",
                      purpose:
                        "Meta Pixel tracking: identifies browsers for advertising measurement",
                      duration: "90 days",
                    },
                    {
                      name: "_fbc",
                      provider: "Meta",
                      purpose:
                        "Meta click tracking: stores Facebook click identifiers when present",
                      duration: "90 days",
                    },
                  ].map(({ name, provider, purpose, duration }) => (
                    <tr class="border-b border-border">
                      <td class="px-4 py-3 font-mono text-xs text-primary">
                        {name}
                      </td>
                      <td class="px-4 py-3 text-foreground/60">{provider}</td>
                      <td class="px-4 py-3 text-foreground/80">{purpose}</td>
                      <td class="px-4 py-3 text-foreground/60">{duration}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>

        <!-- Functional -->
        <div class="mb-6">
          <div class="mb-3 flex items-center gap-3">
            <span class="inline-block h-3 w-3 bg-foreground/40"></span>
            <h3 class="text-lg font-black text-foreground">
              Functional / Preference Cookies
            </h3>
            <span
              class="border border-border px-2 py-0.5 text-xs font-bold text-foreground/60"
              >Optional</span
            >
          </div>
          <p class="mb-4 text-sm leading-relaxed text-foreground/80">
            These cookies enable enhanced functionality and personalization,
            such as remembering your theme or language preference. They may be
            set by us or by third-party providers whose services we have added
            to our pages. If you do not allow these cookies, some or all of
            these services may not function properly.
          </p>
          <div class="overflow-x-auto">
            <table
              class="w-full border border-border bg-card text-sm shadow-2xl"
            >
              <thead>
                <tr class="border-b border-border bg-background/80">
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Cookie</th
                  >
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Purpose</th
                  >
                  <th class="px-4 py-3 text-left font-bold text-foreground"
                    >Duration</th
                  >
                </tr>
              </thead>
              <tbody>
                {
                  [
                    {
                      name: "theme",
                      purpose: "Stores your light/dark mode preference",
                      duration: "1 year",
                    },
                    {
                      name: "ad_tracking_opt_out",
                      purpose:
                        "Records whether this browser has disabled custom ad and conversion event tracking",
                      duration: "Until cleared",
                    },
                  ].map(({ name, purpose, duration }) => (
                    <tr class="border-b border-border">
                      <td class="px-4 py-3 font-mono text-xs text-primary">
                        {name}
                      </td>
                      <td class="px-4 py-3 text-foreground/80">{purpose}</td>
                      <td class="px-4 py-3 text-foreground/60">{duration}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- 3. Third-Party Cookies -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          3. Third-Party Cookies
        </h2>
        <p class="mb-4 leading-relaxed">
          Some cookies on our Website are set by third-party services that
          appear on our pages. We have no direct control over these cookies. The
          following third-party services may set cookies on our Website:
        </p>
        <div class="space-y-3 text-sm">
          {
            [
              {
                service: "Google Analytics",
                purpose:
                  "Website traffic analysis and audience reporting through Google Analytics 4",
                privacy: "https://policies.google.com/privacy",
                optOut: "https://tools.google.com/dlpage/gaoptout",
              },
              {
                service: "Google Ads / Google Tag Manager",
                purpose:
                  "Conversion tracking and remarketing for our own advertising campaigns",
                privacy: "https://policies.google.com/privacy",
                optOut: "https://adssettings.google.com",
              },
              {
                service: "Meta Pixel / Meta Conversions API",
                purpose:
                  "Browser and server-side conversion measurement for our own advertising campaigns",
                privacy: "https://www.facebook.com/privacy/policy/",
                optOut: null,
              },
              {
                service: "Cloudflare",
                purpose: "Security, performance, and DDoS protection",
                privacy: "https://www.cloudflare.com/privacypolicy/",
                optOut: null,
              },
            ].map(({ service, purpose, privacy }) => (
              <div class="border border-border bg-card p-4 shadow-xl">
                <p class="mb-1 font-bold text-foreground">{service}</p>
                <p class="mb-1 text-foreground/80">{purpose}</p>
                <p class="text-foreground/60">
                  Privacy Policy:{" "}
                  <a
                    href={privacy}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary underline underline-offset-2"
                  >
                    {privacy}
                  </a>
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 4. Ad Tracking Opt-Out -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          4. Ad Tracking Opt-Out
        </h2>
        <p class="mb-4 leading-relaxed">
          Custom ad and conversion event tracking is active unless you opt out
          for this browser. You can disable those custom events from our <a
            href={trackingOptOutUrl}
            class="text-primary underline underline-offset-2"
            >Ad Tracking Opt-Out page</a
          >.
        </p>
        <p class="leading-relaxed">
          That page also shows the current tracking status for this browser. The
          opt-out covers events such as product views, checkout clicks, and
          purchase or subscription success events. Basic page-visit measurement,
          security, checkout routing, and essential site features may still
          operate. The opt-out is browser-specific, so using another browser,
          device, private browsing session, or clearing site data may require
          you to opt out again. You can also use your browser settings as
          described in Section 5.
        </p>
      </section>

      <!-- 5. How to Control Cookies -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          5. How to Control and Delete Cookies
        </h2>

        <h3 class="mb-3 text-lg font-bold text-foreground">
          5.1 Browser Settings
        </h3>
        <p class="mb-4 leading-relaxed">
          Most web browsers allow you to control cookies through their settings.
          You can typically:
        </p>
        <ul class="mb-6 space-y-2 text-sm">
          {
            [
              "See what cookies are stored and delete them individually",
              "Block third-party cookies",
              "Block cookies from particular sites",
              "Block all cookies from being set",
              "Delete all cookies when you close your browser",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
        <p class="mb-4 leading-relaxed">Browser-specific instructions:</p>
        <div class="space-y-2 text-sm">
          {
            [
              { browser: "Google Chrome", url: "chrome://settings/cookies" },
              { browser: "Mozilla Firefox", url: "about:preferences#privacy" },
              { browser: "Safari", url: "Safari > Preferences > Privacy" },
              { browser: "Microsoft Edge", url: "edge://settings/privacy" },
            ].map(({ browser, url }) => (
              <div class="flex items-center justify-between border border-border bg-card px-4 py-3 shadow-xl">
                <span class="font-bold text-foreground">{browser}</span>
                <span class="font-mono text-xs text-foreground/60">{url}</span>
              </div>
            ))
          }
        </div>
        <p class="mt-4 text-sm leading-relaxed text-foreground/70">
          Please note that blocking all cookies may affect the functionality of
          many websites, including ours.
        </p>

        <h3 class="mt-6 mb-3 text-lg font-bold text-foreground">
          5.2 Ad and Analytics Opt-Out
        </h3>
        <p class="mb-4 text-sm leading-relaxed">
          You can disable custom ad and conversion event tracking for this
          browser from our <a
            href={trackingOptOutUrl}
            class="text-primary underline underline-offset-2"
            >Ad Tracking Opt-Out page</a
          >. You can also opt out of Google Analytics across all websites using
          the Google Analytics Opt-out Browser Add-on, and manage Google
          advertising cookies through Google's Ads Settings.
        </p>

        <h3 class="mb-3 text-lg font-bold text-foreground">
          5.3 Browser Privacy Controls
        </h3>
        <p class="leading-relaxed">
          Browser privacy settings, content blockers, and third-party cookie
          controls may limit some tracking technologies. Our site-specific
          control for custom ad and conversion event tracking is the Ad Tracking
          Opt-Out page linked above.
        </p>
      </section>

      <!-- 6. Impact of Disabling Cookies -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          6. Impact of Disabling Cookies
        </h2>
        <p class="mb-4 leading-relaxed">
          If you disable cookies (particularly essential cookies), some features
          of the Website may not function as intended. Specifically:
        </p>
        <ul class="space-y-2 text-sm">
          {
            [
              "Forms may not submit correctly",
              "Security protections (CSRF) may not work",
              "Your preferences (theme, language) will not be saved between visits",
              "We will be unable to measure and improve the Website based on your usage",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- 7. Updates -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          7. Updates to This Policy
        </h2>
        <p class="leading-relaxed">
          We may update this Cookie Policy from time to time to reflect changes
          in technology, legislation, or our business practices. When we update
          this policy, we will revise the "Last Updated" date at the top of this
          page. We encourage you to review this page periodically. Significant
          changes will be communicated via a notice on our Website.
        </p>
      </section>

      <!-- 8. Contact -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">8. Contact Us</h2>
        <p class="mb-4 leading-relaxed">
          If you have questions about our use of cookies or this Cookie Policy:
        </p>
        <div
          class="border border-primary/30 bg-primary/5 p-6 shadow-xl backdrop-blur-md"
        >
          <p class="mb-1 font-black text-foreground">{companyName}</p>
          <p class="text-sm text-foreground/80">
            Email: <a
              href={`mailto:${contactEmail}`}
              class="text-primary underline underline-offset-2"
              >{contactEmail}</a
            >
          </p>
          <p class="mt-1 text-sm text-foreground/80">
            Website: <a
              href={websiteUrl}
              class="text-primary underline underline-offset-2">{websiteUrl}</a
            >
          </p>
        </div>
      </section>
    </div>

    <!-- Footer nav -->
    <div class="mt-16 border-t border-border pt-8">
      <p class="mb-4 text-sm font-bold text-foreground">All Policies</p>
      <div class="flex flex-wrap gap-4 text-sm">
        {
          policyLinks.map((policy) => (
            <a
              href={policy.href}
              class="text-primary underline underline-offset-2"
            >
              {policy.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</Layout>

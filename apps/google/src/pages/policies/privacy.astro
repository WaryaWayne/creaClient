---
import PathBreadcrumb from "@/components/PathBreadcrumb"
import Layout from "@/layouts/main.astro"
import { policyLinks } from "@/lib/policies"
import { routes } from "@/lib/routes"
import { getLegalEmail, siteConfig } from "@/lib/site-config"
import type { BreadcrumbList, WebPage, WithContext } from "schema-dts"

const lastUpdated = "January 15, 2025"
const effectiveDate = "January 15, 2025"
const companyName = siteConfig.legalName
const legalEmail = getLegalEmail()
const websiteUrl = siteConfig.rootUrl
const policyName = "Privacy Policy"
const pageTitle = `${policyName} | ${siteConfig.name}`
const pageDescription = `Privacy Policy for ${siteConfig.name}. Learn how we collect, use, and protect your personal information.`
const pageUrl = routes.google.policies.Privacy
const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const policiesUrl = new URL(routes.google.policies.Index, siteUrl).toString()
const trackingOptOutUrl = routes.google.policies.TrackingOptOut

const webPageSchema: WithContext<WebPage> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  breadcrumb: {
    "@id": `${canonicalUrl}#breadcrumb`,
  },
}

const breadcrumbSchema: WithContext<BreadcrumbList> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  name: `${policyName} breadcrumb`,
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Google",
      item: new URL(routes.google.home, siteUrl).toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Policies",
      item: policiesUrl,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: policyName,
      item: canonicalUrl,
    },
  ],
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogType="article"
  ogUrl={pageUrl}
  ogDescription={pageDescription}
  canonical={pageUrl}
  schema={[webPageSchema, breadcrumbSchema]}
>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />

    <!-- Header -->
    <div class="mb-12 border-b border-border pb-10">
      <div
        class="mb-4 inline-block border border-primary/30 bg-primary/10 px-4 py-1.5 text-xs font-semibold tracking-widest text-primary uppercase"
      >
        Legal
      </div>
      <h1 class="mb-4 text-4xl font-black tracking-tight md:text-5xl">
        Privacy Policy
      </h1>
      <div class="flex flex-wrap gap-6 text-sm text-foreground/60">
        <span>Last Updated: {lastUpdated}</span>
        <span>Effective Date: {effectiveDate}</span>
      </div>
    </div>

    <!-- Intro -->
    <div
      class="mb-10 border border-primary/20 bg-primary/5 p-6 shadow-xl backdrop-blur-sm"
    >
      <p class="text-sm leading-relaxed text-foreground">
        <strong class="text-foreground">Plain-English Summary:</strong> We collect
        information you give us (like your name and email when you fill out a form),
        information about how you use our website (like pages visited), and information
        related to the services we provide. We use that information to deliver our
        services, communicate with you, and improve our business. We don't sell your
        personal information. Ever. You can disable our custom ad and conversion event
        tracking for this browser from our <a
          href={trackingOptOutUrl}
          class="text-primary underline underline-offset-2"
          >Ad Tracking Opt-Out page</a
        >. If you have questions, email us at <a
          href={`mailto:${legalEmail}`}
          class="text-primary underline underline-offset-2">{legalEmail}</a
        >.
      </p>
    </div>

    <div class="prose-policy space-y-10 text-foreground">
      <!-- 1. Who We Are -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">1. Who We Are</h2>
        <p class="mb-4 leading-relaxed">
          {companyName} ("Company," "we," "our," or "us") operates the website located
          at <a
            href={websiteUrl}
            class="text-primary underline underline-offset-2">{websiteUrl}</a
          > (the "Website") and provides Google Ads optimization, audit, and management
          services (collectively, the "Services").
        </p>
        <p class="leading-relaxed">
          This Privacy Policy explains how we collect, use, disclose, and
          safeguard your information when you visit our Website or use our
          Services. Please read it carefully. If you disagree with the terms of
          this Privacy Policy, please discontinue use of the Website and
          Services.
        </p>
      </section>

      <!-- 2. Information We Collect -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          2. Information We Collect
        </h2>

        <h3 class="mb-3 text-lg font-bold text-foreground">
          2.1 Information You Provide Directly
        </h3>
        <p class="mb-4 leading-relaxed">
          We collect information you voluntarily provide when you:
        </p>
        <ul class="mb-6 space-y-2 text-sm">
          {
            [
              "Fill out a contact form or intake form on our Website",
              "Request an audit, proposal, or quote",
              "Sign up for our newsletter or email communications",
              "Purchase or engage with our Services",
              "Communicate with us via email, phone, or other channels",
              "Grant us access to your Google Ads account for the purpose of our Services",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
        <p class="mb-6 leading-relaxed">
          The types of personal information you may provide include: full name,
          business name, email address, phone number, mailing address, monthly
          advertising budget, billing information, Google Ads account
          credentials (read-only access), and any other information you choose
          to share.
        </p>

        <h3 class="mb-3 text-lg font-bold text-foreground">
          2.2 Information Collected Automatically
        </h3>
        <p class="mb-4 leading-relaxed">
          When you visit our Website, we may automatically collect certain
          information about your device and browsing activity, including:
        </p>
        <ul class="mb-6 space-y-2 text-sm">
          {
            [
              "IP address and approximate geographic location (city/region level)",
              "Browser type and version",
              "Operating system",
              "Pages visited and time spent on each page",
              "Referring URL (the page you visited before arriving at our site)",
              "Date and time of your visit",
              "Links clicked and actions taken on the Website",
              "Device identifiers and screen resolution",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>

        <h3 class="mb-3 text-lg font-bold text-foreground">
          2.3 Information from Third-Party Platforms
        </h3>
        <p class="leading-relaxed">
          In the course of delivering our Services, we may access data from
          third-party advertising platforms, primarily Google Ads, that you
          authorize us to access. This data is used solely to perform the
          Services you have engaged us for and is not used for any other
          purpose, shared with third parties, or retained beyond the scope of
          the engagement.
        </p>
      </section>

      <!-- 3. Cookies and Tracking -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          3. Cookies and Tracking Technologies
        </h2>
        <p class="mb-4 leading-relaxed">
          We use cookies, web beacons, pixels, and similar tracking technologies
          to collect information about how you interact with our Website. These
          technologies help us understand user behavior, measure ad performance,
          remember your preferences, and improve our services. We currently use
          Google Analytics 4, Google Ads conversion tracking, Meta Pixel, and
          Meta Conversions API server-side events for measurement and
          advertising. We may measure basic page visits and site performance. We
          may also send custom ad and conversion events, such as product views,
          checkout clicks, and purchase or subscription success events, unless
          you opt out for this browser.
        </p>
        <p class="mb-4 leading-relaxed">The types of cookies we use include:</p>
        <div class="mb-4 space-y-4">
          {
            [
              {
                type: "Essential Cookies",
                desc: "Required for the Website to function. These cannot be disabled. They include session management and security cookies.",
              },
              {
                type: "Analytics Cookies",
                desc: "Help us understand page visits and site performance through tools such as Google Analytics 4.",
              },
              {
                type: "Marketing Cookies",
                desc: "Used to measure selected ad and conversion events through tools such as Google Ads, Meta Pixel, and Meta Conversions API.",
              },
              {
                type: "Preference Cookies",
                desc: "Allow the Website to remember choices you make (such as language or theme preferences) to provide a more personalized experience.",
              },
            ].map(({ type, desc }) => (
              <div class="border border-border bg-card p-4 shadow-xl">
                <p class="mb-1 text-sm font-bold text-foreground">{type}</p>
                <p class="text-sm leading-relaxed text-foreground/80">{desc}</p>
              </div>
            ))
          }
        </div>
        <p class="leading-relaxed">
          You can control cookies through your browser settings. You can disable
          our custom ad and conversion event tracking for this browser from our <a
            href={trackingOptOutUrl}
            class="text-primary underline underline-offset-2"
            >Ad Tracking Opt-Out page</a
          >, which also shows the current tracking status for this browser. Note
          that basic page-visit measurement, security, checkout routing, and
          essential site features may still operate. For more detailed
          information, see our <a
            href={routes.google.policies.Cookies}
            class="text-primary underline underline-offset-2">Cookie Policy</a
          >.
        </p>
      </section>

      <!-- 4. How We Use Your Information -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          4. How We Use Your Information
        </h2>
        <p class="mb-4 leading-relaxed">
          We use the information we collect for the following purposes:
        </p>
        <div class="space-y-3">
          {
            [
              {
                label: "Delivering Services",
                desc: "To fulfill the Google Ads audit, optimization, and management services you have engaged us for.",
              },
              {
                label: "Communication",
                desc: "To respond to your inquiries, send service-related emails, provide updates on your project, and follow up on proposals.",
              },
              {
                label: "Billing and Payments",
                desc: "To process payments and maintain financial records in accordance with legal obligations.",
              },
              {
                label: "Website Improvement",
                desc: "To analyze how our Website is used, identify issues, and improve functionality and content.",
              },
              {
                label: "Marketing",
                desc: "To send you information about our services, offers, and updates where permitted, and to measure or improve our advertising. You can opt out at any time.",
              },
              {
                label: "Legal Compliance",
                desc: "To comply with applicable laws and regulations, respond to legal requests, and enforce our agreements.",
              },
              {
                label: "Security",
                desc: "To detect, prevent, and respond to fraud, abuse, and security threats.",
              },
              {
                label: "Business Operations",
                desc: "To administer our business, improve internal processes, and conduct analytics for internal reporting.",
              },
            ].map(({ label, desc }) => (
              <div class="flex gap-4 border border-border bg-card p-4 shadow-xl">
                <span class="mt-0.5 h-1.5 w-1.5 shrink-0 bg-primary" />
                <div>
                  <p class="mb-1 text-sm font-bold text-foreground">{label}</p>
                  <p class="text-sm leading-relaxed text-foreground/80">
                    {desc}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 5. Legal Basis -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          5. Legal Basis for Processing (GDPR / PIPEDA)
        </h2>
        <p class="mb-4 leading-relaxed">
          Where applicable, we process your personal information on the
          following legal bases:
        </p>
        <ul class="space-y-3 text-sm">
          {
            [
              {
                basis: "Contract Performance",
                desc: "Processing is necessary to fulfill our contractual obligations to you (e.g., delivering the service you paid for).",
              },
              {
                basis: "Legitimate Interests",
                desc: "Processing is necessary for our legitimate business interests (e.g., improving our website, preventing fraud), where these interests are not overridden by your rights.",
              },
              {
                basis: "Direct Marketing Preferences",
                desc: "You can unsubscribe from marketing emails and disable custom ad and conversion event tracking for this browser.",
              },
              {
                basis: "Legal Obligation",
                desc: "Processing is necessary to comply with a legal obligation (e.g., tax record-keeping).",
              },
            ].map(({ basis, desc }) => (
              <li class="border border-border bg-card p-4 shadow-xl">
                <p class="mb-1 font-bold text-foreground">{basis}</p>
                <p class="leading-relaxed text-foreground/80">{desc}</p>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- 6. Sharing Information -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          6. How We Share Your Information
        </h2>
        <p class="mb-4 leading-relaxed">
          We do not sell, rent, or trade your personal information to third
          parties. We may share your information only in the following limited
          circumstances:
        </p>
        <div class="space-y-3 text-sm">
          {
            [
              {
                title: "Service Providers",
                body: "We engage trusted third-party vendors to perform functions on our behalf, such as payment processing, email delivery, analytics, and hosting. These vendors have access to personal information only as necessary to perform their functions and are contractually bound to protect it.",
              },
              {
                title: "Google LLC",
                body: "Our services involve accessing Google's advertising platform. Information necessary to provide the Services may be processed through Google's systems. Google's privacy practices are governed by their Privacy Policy.",
              },
              {
                title: "Legal Requirements",
                body: "We may disclose your information if required to do so by law, court order, or government authority, or if we believe disclosure is necessary to protect our rights, protect your safety or the safety of others, investigate fraud, or comply with a legal obligation.",
              },
              {
                title: "Business Transfers",
                body: "In the event of a merger, acquisition, sale of assets, or other corporate transaction, your personal information may be transferred as part of that transaction. We will notify you before your personal information becomes subject to a different privacy policy.",
              },
              {
                title: "With Your Direction",
                body: "We may share your information with third parties when you ask us to do so or when it is needed to provide a service you requested.",
              },
            ].map(({ title, body }) => (
              <div class="border border-border bg-card p-4 shadow-xl">
                <p class="mb-1 font-bold text-foreground">{title}</p>
                <p class="leading-relaxed text-foreground/80">{body}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 7. Data Retention -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          7. Data Retention
        </h2>
        <p class="mb-4 leading-relaxed">
          We retain personal information for as long as necessary to fulfill the
          purposes outlined in this Privacy Policy, unless a longer retention
          period is required or permitted by law.
        </p>
        <ul class="space-y-2 text-sm">
          {
            [
              "Client records and service-related data: Up to 7 years from the end of the engagement (for tax and legal compliance)",
              "Contact form submissions (non-clients): Up to 12 months, or until you request deletion",
              "Marketing email lists: Until you unsubscribe or request removal",
              "Website analytics data: Up to 26 months",
              "Google Ads account access: Revoked at the conclusion of the engagement",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- 8. Your Rights -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          8. Your Rights and Choices
        </h2>
        <p class="mb-4 leading-relaxed">
          Depending on your location, you may have certain rights regarding your
          personal information. These may include:
        </p>
        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
          {
            [
              {
                right: "Right to Access",
                desc: "Request a copy of the personal information we hold about you.",
              },
              {
                right: "Right to Rectification",
                desc: "Request that we correct inaccurate or incomplete information.",
              },
              {
                right: "Right to Erasure",
                desc: 'Request that we delete your personal information ("right to be forgotten"), subject to legal obligations.',
              },
              {
                right: "Right to Restriction",
                desc: "Request that we limit how we use your personal information.",
              },
              {
                right: "Right to Portability",
                desc: "Request a machine-readable copy of your data to transfer to another service.",
              },
              {
                right: "Right to Object",
                desc: "Object to our processing of your data based on legitimate interests or for direct marketing.",
              },
              {
                right: "Right to Opt Out",
                desc: "Unsubscribe from marketing messages or disable custom ad and conversion event tracking for this browser.",
              },
              {
                right: "Right to Complain",
                desc: "Lodge a complaint with your relevant data protection authority.",
              },
            ].map(({ right, desc }) => (
              <div class="border border-border bg-card p-4 shadow-xl">
                <p class="mb-1 text-sm font-bold text-foreground">{right}</p>
                <p class="text-sm leading-relaxed text-foreground/80">{desc}</p>
              </div>
            ))
          }
        </div>
        <p class="mt-4 leading-relaxed">
          To exercise any of these rights, please contact us at <a
            href={`mailto:${legalEmail}`}
            class="text-primary underline underline-offset-2">{legalEmail}</a
          >. We will respond within 30 days. We may need to verify your identity
          before processing your request.
        </p>
      </section>

      <!-- 9. Security -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          9. Data Security
        </h2>
        <p class="mb-4 leading-relaxed">
          We implement appropriate technical and organizational security
          measures designed to protect your personal information from
          unauthorized access, use, alteration, and disclosure. These measures
          include:
        </p>
        <ul class="mb-4 space-y-2 text-sm">
          {
            [
              "Encrypted data transmission using TLS/SSL protocols",
              "Access controls limiting who can view personal information",
              "Using Google's official Manager Account (MCC) system for read-only ad account access",
              "Regular review of our security practices",
              "Contractual data protection requirements with our service providers",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
        <p class="leading-relaxed">
          However, no method of transmission over the Internet or electronic
          storage is 100% secure. While we strive to use commercially acceptable
          means to protect your personal information, we cannot guarantee its
          absolute security.
        </p>
      </section>

      <!-- 10. Third-Party Links -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          10. Third-Party Links and Services
        </h2>
        <p class="leading-relaxed">
          Our Website may contain links to third-party websites, including
          Google's platforms and payment processors. These third parties have
          their own privacy policies, and we are not responsible for their
          practices. We encourage you to review the privacy policy of every
          website you visit. Our use of any linked services does not imply
          endorsement.
        </p>
      </section>

      <!-- 11. Children's Privacy -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          11. Children's Privacy
        </h2>
        <p class="leading-relaxed">
          Our Services are not directed to individuals under the age of 18. We
          do not knowingly collect personal information from children. If you
          are a parent or guardian and believe your child has provided us with
          personal information, please contact us immediately at <a
            href={`mailto:${legalEmail}`}
            class="text-primary underline underline-offset-2">{legalEmail}</a
          > and we will delete such information from our records.
        </p>
      </section>

      <!-- 12. International Transfers -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          12. International Data Transfers
        </h2>
        <p class="leading-relaxed">
          Our operations are primarily based in North America. If you are
          located outside of Canada or the United States, please be aware that
          your information may be transferred to, stored, and processed in these
          countries, where data protection laws may differ from those in your
          jurisdiction. Where required by law, we take steps to ensure
          appropriate safeguards are in place.
        </p>
      </section>

      <!-- 13. Changes -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          13. Changes to This Privacy Policy
        </h2>
        <p class="leading-relaxed">
          We may update this Privacy Policy from time to time. We will notify
          you of any changes by posting the new policy on this page with an
          updated "Last Updated" date. For material changes, we will provide
          more prominent notice (such as an email notification if we have your
          contact information). Your continued use of the Website or Services
          after any changes constitutes your acceptance of the updated policy.
        </p>
      </section>

      <!-- 14. Contact -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">14. Contact Us</h2>
        <p class="mb-4 leading-relaxed">
          If you have any questions, concerns, or requests regarding this
          Privacy Policy or our data practices, please contact us:
        </p>
        <div
          class="border border-primary/30 bg-primary/5 p-6 shadow-xl backdrop-blur-md"
        >
          <p class="mb-1 font-black text-foreground">{companyName}</p>
          <p class="text-sm text-foreground/80">
            Email: <a
              href={`mailto:${legalEmail}`}
              class="text-primary underline underline-offset-2"
              >{legalEmail}</a
            >
          </p>
          <p class="mt-4 text-xs text-foreground/60">
            We aim to respond to all privacy-related inquiries within 5 business
            days.
          </p>
        </div>
      </section>
    </div>

    <!-- Footer nav -->
    <div class="mt-16 border-t border-border pt-8">
      <p class="mb-4 text-sm font-bold text-foreground">All Policies</p>
      <div class="flex flex-wrap gap-4 text-sm">
        {
          policyLinks.map((policy) => (
            <a
              href={policy.href}
              class="text-primary underline underline-offset-2"
            >
              {policy.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</Layout>

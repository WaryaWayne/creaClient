---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import { policyLinks } from "@/lib/policies"
import type { BreadcrumbList, WebPage, WithContext } from "schema-dts"
import { routes } from "@/lib/routes"
import { getLegalEmail, siteConfig } from "@/lib/site-config"

const lastUpdated = "January 15, 2025"
const companyName = siteConfig.legalName
const contactEmail = getLegalEmail()
const websiteUrl = siteConfig.rootUrl
const policyName = "Disclaimer"
const pageTitle = `${policyName} | ${siteConfig.name}`
const pageDescription = `Legal disclaimer for ${siteConfig.name}. No guarantees of advertising results. Not affiliated with Google LLC.`
const pageUrl = routes.google.policies.Disclaimer
const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const policiesUrl = new URL(routes.google.policies.Index, siteUrl).toString()

const webPageSchema: WithContext<WebPage> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  breadcrumb: {
    "@id": `${canonicalUrl}#breadcrumb`,
  },
}

const breadcrumbSchema: WithContext<BreadcrumbList> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  name: `${policyName} breadcrumb`,
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Google",
      item: new URL(routes.google.home, siteUrl).toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Policies",
      item: policiesUrl,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: policyName,
      item: canonicalUrl,
    },
  ],
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogType="article"
  ogUrl={pageUrl}
  ogDescription={pageDescription}
  canonical={pageUrl}
  schema={[webPageSchema, breadcrumbSchema]}
>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />

    <!-- Header -->
    <div class="mb-12 border-b border-border pb-10">
      <div
        class="mb-4 inline-block border border-primary/30 bg-primary/10 px-4 py-1.5 text-xs font-semibold tracking-widest text-primary uppercase"
      >
        Legal
      </div>
      <h1 class="mb-4 text-4xl font-black tracking-tight md:text-5xl">
        Disclaimer
      </h1>
      <div class="flex flex-wrap gap-6 text-sm text-foreground/60">
        <span>Last Updated: {lastUpdated}</span>
      </div>
    </div>

    <!-- Intro -->
    <div
      class="mb-10 border border-primary/20 bg-primary/5 p-6 shadow-xl backdrop-blur-sm"
    >
      <p class="text-sm leading-relaxed text-foreground">
        <strong class="text-foreground">Plain-English Summary:</strong> We're a Google
        Ads consulting company. We are not Google. Results shown on our Website are
        real past outcomes. They are not guarantees. The information on this site
        is for general informational purposes and should not be taken as a promise
        of specific advertising performance for your business.
      </p>
    </div>

    <div class="space-y-10 text-foreground">
      <!-- 1. No Affiliation -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          1. No Affiliation with Google LLC
        </h2>
        <div
          class="mb-4 border border-destructive/30 bg-destructive/5 p-5 shadow-xl backdrop-blur-sm"
        >
          <p class="mb-2 text-sm font-bold text-foreground">Important Notice</p>
          <p class="text-sm leading-relaxed text-foreground/80">
            {companyName} is an independent advertising consultancy. We are not affiliated
            with, endorsed by, sponsored by, or in any way officially connected to
            Google LLC, Alphabet Inc., or any of their subsidiaries or affiliates.
            The name "Google," "Google Ads," "Google Analytics," "Google Business
            Profile," and related marks are trademarks of Google LLC.
          </p>
        </div>
        <p class="leading-relaxed">
          We use Google's publicly available advertising platform, tools, and
          APIs to provide our services to clients. Any references to Google
          products on our Website are for descriptive purposes only and do not
          imply any formal partnership or relationship.
        </p>
      </section>

      <!-- 2. No Results Guarantee -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          2. No Guarantee of Advertising Results
        </h2>
        <p class="mb-4 leading-relaxed">
          Advertising performance is inherently variable and is influenced by a
          large number of factors, many of which are entirely outside our
          control. These include but are not limited to:
        </p>
        <ul class="mb-6 space-y-2 text-sm">
          {
            [
              "Your industry, competitive landscape, and local market conditions",
              "Your advertising budget and how much you bid",
              "The quality and relevance of your landing pages and website",
              "Your business's offer, pricing, and value proposition",
              "Seasonal demand fluctuations",
              "Google algorithm updates and changes to auction dynamics",
              "Google's Quality Score system and ad rank calculations",
              "Changes to Google's advertising policies or platform features",
              "Broader economic conditions affecting consumer behavior",
              "Whether and how you implement our recommendations",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
        <p class="leading-relaxed">
          Nothing on our Website, in our marketing materials, in our sales
          conversations, or in any deliverable we produce constitutes a
          guarantee or warranty of specific advertising results, including but
          not limited to: clicks, impressions, leads, calls, conversions,
          revenue, return on ad spend (ROAS), cost per lead (CPL), or any other
          metric.
        </p>
      </section>

      <!-- 3. Testimonials and Case Studies -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          3. Testimonials, Case Studies, and Statistics
        </h2>
        <p class="mb-4 leading-relaxed">
          Any testimonials, case studies, statistics, before/after comparisons,
          or performance figures displayed on our Website reflect real outcomes
          achieved by real clients. They are provided for illustrative purposes
          only.
        </p>
        <p class="mb-4 leading-relaxed">
          These results are not typical. Individual results will vary
          significantly based on the factors described in Section 2. The fact
          that one business improved its advertising efficiency does not mean
          you will achieve the same. The fact that one business halved their
          cost per lead does not mean your cost per lead will decrease at all.
        </p>
        <p class="leading-relaxed">
          Where we describe audit timing, review scope, or support windows,
          those statements describe our service process. They should not be
          interpreted as predictions of your individual advertising outcomes.
        </p>
      </section>

      <!-- 4. General Information Only -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          4. General Informational Content
        </h2>
        <p class="mb-4 leading-relaxed">
          The content on our Website, including blog posts, guides, tips,
          educational content, and descriptions of Google Ads concepts, is
          provided for general informational purposes only. While we endeavor to
          keep this information accurate and up to date, Google's advertising
          platform changes frequently and some information may become outdated.
        </p>
        <p class="leading-relaxed">
          Nothing on this Website constitutes professional advertising, legal,
          financial, or business advice specific to your situation. You should
          evaluate all information in light of your specific circumstances.
          Decisions about your advertising budget, strategy, or approach should
          be made using your own judgment, your own research, and consultation
          with relevant professionals as appropriate.
        </p>
      </section>

      <!-- 5. External Links -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          5. External Links
        </h2>
        <p class="leading-relaxed">
          Our Website may contain links to third-party websites, including
          Google's platforms, news articles, or other resources. These links are
          provided for your convenience and reference only. We have no control
          over the content, accuracy, or availability of these external sites,
          and we do not endorse or accept responsibility for the content found
          there. A link to a third-party website does not imply our endorsement
          or approval.
        </p>
      </section>

      <!-- 6. Platform Changes -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          6. Google Platform Changes
        </h2>
        <p class="leading-relaxed">
          Google Ads is a third-party platform that changes frequently. Google
          may at any time modify, discontinue, or change features of its
          advertising platform, alter its auction algorithms, update Quality
          Score factors, change minimum bid requirements, suspend advertising
          accounts, or alter any other aspect of its service. These changes may
          affect the performance of campaigns we have built, audited, or managed
          for you. {companyName} is not responsible for the impact of any Google platform
          changes on advertising performance.
        </p>
      </section>

      <!-- 7. No Professional Advice -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          7. No Legal, Financial, or Tax Advice
        </h2>
        <p class="leading-relaxed">
          Nothing on this Website or in any of our deliverables constitutes
          legal, financial, investment, or tax advice. We are advertising
          consultants, not lawyers, accountants, or financial advisors. Any
          reference to pricing, budgets, ROI, or financial projections is for
          illustrative purposes only. You should consult qualified legal and
          financial professionals regarding your own circumstances.
        </p>
      </section>

      <!-- 8. Accuracy of Information -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          8. Accuracy of Information on This Website
        </h2>
        <p class="leading-relaxed">
          While we make every effort to ensure the accuracy of information
          presented on this Website, we make no representations or warranties of
          any kind, express or implied, about the completeness, accuracy,
          reliability, suitability, or availability of any information,
          products, services, or related graphics. Any reliance you place on
          such information is strictly at your own risk.
        </p>
      </section>

      <!-- 9. Limitation -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          9. Limitation of Liability
        </h2>
        <p class="leading-relaxed">
          To the fullest extent permitted by law, {companyName}, its owners,
          employees, and contractors shall not be liable for any loss, damage,
          or expense, whether direct, indirect, incidental, special,
          consequential, or otherwise, arising out of your use of this Website
          or reliance on any information contained herein. This includes,
          without limitation, loss of data, loss of profits, or business
          interruption. This limitation applies even if we have been advised of
          the possibility of such damages. For full liability terms, see our <a
            href={routes.google.policies.TermsOfService}
            class="text-primary underline underline-offset-2"
            >Terms of Service</a
          >.
        </p>
      </section>

      <!-- 10. Contact -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">10. Contact</h2>
        <p class="mb-4 leading-relaxed">
          Questions about this Disclaimer? Contact us:
        </p>
        <div
          class="border border-primary/30 bg-primary/5 p-6 shadow-xl backdrop-blur-md"
        >
          <p class="mb-1 font-black text-foreground">{companyName}</p>
          <p class="text-sm text-foreground/80">
            Email: <a
              href={`mailto:${contactEmail}`}
              class="text-primary underline underline-offset-2"
              >{contactEmail}</a
            >
          </p>
          <p class="mt-1 text-sm text-foreground/80">
            Website: <a
              href={websiteUrl}
              class="text-primary underline underline-offset-2">{websiteUrl}</a
            >
          </p>
        </div>
      </section>
    </div>

    <!-- Footer nav -->
    <div class="mt-16 border-t border-border pt-8">
      <p class="mb-4 text-sm font-bold text-foreground">All Policies</p>
      <div class="flex flex-wrap gap-4 text-sm">
        {
          policyLinks.map((policy) => (
            <a
              href={policy.href}
              class="text-primary underline underline-offset-2"
            >
              {policy.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</Layout>

---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import { policyLinks } from "@/lib/policies"
import type { BreadcrumbList, WebPage, WithContext } from "schema-dts"
import { routes } from "@/lib/routes"
import { getLegalEmail, siteConfig } from "@/lib/site-config"

const lastUpdated = "January 15, 2025"
const companyName = siteConfig.legalName
const contactEmail = getLegalEmail()
const websiteUrl = siteConfig.rootUrl
const policyName = "Acceptable Use Policy"
const pageTitle = `${policyName} | ${siteConfig.name}`
const pageDescription = `Acceptable Use Policy for ${siteConfig.name}. Rules governing permitted and prohibited use of our website and services.`
const pageUrl = routes.google.policies.AcceptableUse
const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const policiesUrl = new URL(routes.google.policies.Index, siteUrl).toString()

const webPageSchema: WithContext<WebPage> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  breadcrumb: {
    "@id": `${canonicalUrl}#breadcrumb`,
  },
}

const breadcrumbSchema: WithContext<BreadcrumbList> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  name: `${policyName} breadcrumb`,
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Google",
      item: new URL(routes.google.home, siteUrl).toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Policies",
      item: policiesUrl,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: policyName,
      item: canonicalUrl,
    },
  ],
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogType="article"
  ogUrl={pageUrl}
  ogDescription={pageDescription}
  canonical={pageUrl}
  schema={[webPageSchema, breadcrumbSchema]}
>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />

    <!-- Header -->
    <div class="mb-12 border-b border-border pb-10">
      <div
        class="mb-4 inline-block border border-primary/30 bg-primary/10 px-4 py-1.5 text-xs font-semibold tracking-widest text-primary uppercase"
      >
        Legal
      </div>
      <h1 class="mb-4 text-4xl font-black tracking-tight md:text-5xl">
        Acceptable Use Policy
      </h1>
      <div class="flex flex-wrap gap-6 text-sm text-foreground/60">
        <span>Last Updated: {lastUpdated}</span>
      </div>
    </div>

    <!-- Intro -->
    <div
      class="mb-10 border border-primary bg-primary/5 backdrop-blur-sm p-6 shadow-xl"
    >
      <p class="text-sm leading-relaxed text-foreground">
        <strong class="text-foreground">Plain-English Summary:</strong> Use our website
        and services for legal, legitimate business advertising purposes. Don't try
        to advertise illegal products, deceive consumers, abuse our platform, or scrape
        our site. Don't ask us to run campaigns that violate Google's policies or
        the law. If you do, we'll end the engagement immediately. Full details below.
      </p>
    </div>

    <div class="space-y-10 text-foreground">
      <!-- 1. Purpose -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          1. Purpose and Scope
        </h2>
        <p class="mb-4 leading-relaxed">
          This Acceptable Use Policy ("AUP") governs your use of the {
            companyName
          } website located at {websiteUrl} (the "Website") and all services provided
          by {companyName} ("Company," "we," "our," or "us").
        </p>
        <p class="leading-relaxed">
          This AUP is incorporated into and forms part of our <a
            href={routes.google.policies.TermsOfService}
            class="text-primary underline underline-offset-2"
            >Terms of Service</a
          >. By using the Website or Services, you agree to comply with this
          AUP. We reserve the right to update this policy at any time. Continued
          use of the Website or Services following any changes constitutes
          acceptance of the revised AUP.
        </p>
      </section>

      <!-- 2. Permitted Uses -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          2. Permitted Uses
        </h2>
        <p class="mb-4 leading-relaxed">
          You may use our Website and Services for lawful purposes related to
          improving your business's digital advertising. Permitted uses include:
        </p>
        <ul class="space-y-2 text-sm">
          {
            [
              "Accessing information about our Services for evaluation purposes",
              "Submitting contact forms or intake forms with accurate information about yourself and your business",
              "Purchasing Services for legitimate advertising of legal products and services",
              "Granting us access to your Google Ads account for the sole purpose of delivering the Services you have engaged",
              "Communicating with us via the channels provided on our Website",
              "Downloading or printing information from our Website for your own personal, non-commercial use",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- 3. Prohibited Uses -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          3. Prohibited Uses
        </h2>
        <p class="mb-4 leading-relaxed">
          The following uses of our Website and Services are strictly
          prohibited. You may not use our Website or Services to:
        </p>

        <h3 class="mb-3 text-lg font-bold text-foreground">
          3.1 Illegal Activities
        </h3>
        <ul class="mb-6 space-y-2 text-sm">
          {
            [
              "Advertise, promote, or facilitate the sale of any illegal product or service in the applicable jurisdiction",
              "Engage in fraud, deception, or misrepresentation of any kind",
              "Violate any applicable local, provincial, state, national, or international law or regulation",
              "Infringe upon the intellectual property rights, privacy rights, or other rights of any third party",
              "Engage in money laundering or any transaction that violates financial crime laws",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>

        <h3 class="mb-3 text-lg font-bold text-foreground">
          3.2 Prohibited Advertising Content
        </h3>
        <p class="mb-3 text-sm leading-relaxed text-foreground/80">
          You may not engage us to create, set up, or manage advertising
          campaigns for the following types of businesses or content (this list
          is illustrative, not exhaustive):
        </p>
        <ul class="mb-6 space-y-2 text-sm">
          {
            [
              "Counterfeit goods or trademark infringement",
              "Illegal drugs, controlled substances, or drug paraphernalia",
              "Weapons, firearms, or ammunition where prohibited by law",
              "Tobacco, cigarettes, or vaping products (unless in compliance with all applicable regulations)",
              "Adult content or sexually explicit material",
              "Gambling operations not licensed in the applicable jurisdiction",
              "Pyramid schemes, multi-level marketing using deceptive claims, or Ponzi schemes",
              "Fake credentials, academic dishonesty services, or essay mills",
              "Malware, spyware, or harmful software",
              "Impersonation of any person, entity, or brand",
              "Content that promotes violence, hatred, or discrimination",
              '"Get rich quick" schemes or misleading financial products',
              "Any content that violates Google Ads policies",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>

        <h3 class="mb-3 text-lg font-bold text-foreground">
          3.3 Website Abuse
        </h3>
        <p class="mb-4 text-sm leading-relaxed text-foreground/80">
          You may not:
        </p>
        <ul class="mb-6 space-y-2 text-sm">
          {
            [
              "Attempt to gain unauthorized access to any part of the Website or our systems",
              "Use automated tools, bots, scrapers, or crawlers to extract content from our Website without our written permission",
              "Submit false, misleading, or fraudulent information via any form on our Website",
              "Attempt to probe, scan, or test the security or vulnerability of our Website or systems",
              "Interfere with or disrupt the integrity or performance of our Website",
              "Transmit any malicious code, viruses, trojans, or other harmful software via our Website",
              "Engage in denial-of-service attacks or distributed denial-of-service attacks",
              "Impersonate another user, person, or entity when communicating with us",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>

        <h3 class="mb-3 text-lg font-bold text-foreground">
          3.4 Misuse of Services
        </h3>
        <ul class="space-y-2 text-sm">
          {
            [
              "Use our Services to reverse-engineer our proprietary methodologies for the purpose of creating a competing service",
              "Share, sublicense, or resell our deliverables or methodologies to third parties without our written permission",
              "Provide false information about your business, industry, or advertising account in order to obtain Services",
              "Attempt to access or interfere with other clients' advertising accounts",
              "Use information gained through our Services to harm other businesses or engage in unfair competitive practices that violate applicable law",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- 4. Google Ads Policy Compliance -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          4. Google Ads Policy Compliance
        </h2>
        <p class="mb-4 leading-relaxed">
          Our Services involve the use of Google's advertising platform. You
          acknowledge and agree that:
        </p>
        <ul class="space-y-2 text-sm">
          {
            [
              "You are responsible for ensuring your business, products, services, and advertising content comply with all applicable Google Ads policies at all times",
              "We may decline to create, run, or manage any campaign that we believe violates Google's policies, even if that campaign would otherwise be legal",
              "You will not ask or instruct us to circumvent, work around, or violate Google's advertising policies",
              "A suspension or disapproval by Google does not automatically entitle you to a refund if the suspension results from your own non-compliance",
              "We will immediately notify you if we identify a policy compliance risk and will not proceed with that element of the campaign until resolved",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- 5. Consequences -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          5. Consequences of Violation
        </h2>
        <p class="mb-4 leading-relaxed">
          If we determine, in our sole discretion, that you have violated this
          AUP, we may:
        </p>
        <ul class="mb-4 space-y-2 text-sm">
          {
            [
              "Immediately suspend or terminate your access to our Services without notice",
              "Revoke our access to your advertising accounts",
              "Withhold or forfeit any refund otherwise owed",
              "Report the violation to Google, law enforcement, or other appropriate authorities",
              "Take legal action to recover damages or injunctive relief",
              "Notify affected third parties where required by law",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 bg-primary" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
        <p class="leading-relaxed">
          We also reserve the right to decline new service requests from any
          individual or business that has previously violated this AUP.
        </p>
      </section>

      <!-- 6. Reporting -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          6. Reporting Violations
        </h2>
        <p class="leading-relaxed">
          If you become aware of any use of our Website or Services that
          violates this AUP, please report it to us at <a
            href={`mailto:${contactEmail}`}
            class="text-primary underline underline-offset-2">{contactEmail}</a
          >. We take all reports seriously and will investigate and respond as
          appropriate.
        </p>
      </section>

      <!-- 7. Contact -->
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">7. Contact Us</h2>
        <p class="mb-4 leading-relaxed">
          Questions about this Acceptable Use Policy:
        </p>
        <div
          class="border border-primary/30 bg-primary/5 p-6 shadow-xl backdrop-blur-md"
        >
          <p class="mb-1 font-black text-foreground">{companyName}</p>
          <p class="text-sm text-foreground/80">
            Email: <a
              href={`mailto:${contactEmail}`}
              class="text-primary underline underline-offset-2"
              >{contactEmail}</a
            >
          </p>
        </div>
      </section>
    </div>

    <!-- Footer nav -->
    <div class="mt-16 border-t border-border pt-8">
      <p class="mb-4 text-sm font-bold text-foreground">All Policies</p>
      <div class="flex flex-wrap gap-4 text-sm">
        {
          policyLinks.map((policy) => (
            <a
              href={policy.href}
              class="text-primary underline underline-offset-2"
            >
              {policy.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</Layout>

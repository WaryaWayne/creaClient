---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import { policyLinks } from "@/lib/policies"
import { routes } from "@/lib/routes"
import { siteConfig } from "@/lib/site-config"
import { ShieldCheck, ShieldOff } from "lucide-react"
import type { BreadcrumbList, WebPage, WithContext } from "schema-dts"

const lastUpdated = "May 1, 2026"
const policyName = "Ad Tracking Opt-Out"
const pageTitle = `${policyName} | ${siteConfig.name} | 2To6X`
const pageDescription = `Manage whether this browser sends custom ad and conversion events on ${siteConfig.name}.`
const pageUrl = routes.google.policies.TrackingOptOut
const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const policiesUrl = new URL(routes.google.policies.Index, siteUrl).toString()

const webPageSchema: WithContext<WebPage> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  breadcrumb: {
    "@id": `${canonicalUrl}#breadcrumb`,
  },
}

const breadcrumbSchema: WithContext<BreadcrumbList> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  name: `${policyName} breadcrumb`,
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Google",
      item: new URL(routes.google.home, siteUrl).toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Policies",
      item: policiesUrl,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: policyName,
      item: canonicalUrl,
    },
  ],
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogType="article"
  ogUrl={pageUrl}
  ogDescription={pageDescription}
  canonical={pageUrl}
  schema={[webPageSchema, breadcrumbSchema]}
>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />

    <div class="mb-12 border-b border-border pb-10">
      <div
        class="mb-4 inline-block border border-primary/30 bg-primary/10 px-4 py-1.5 text-xs font-semibold tracking-widest text-primary uppercase"
      >
        Legal
      </div>
      <h1 class="mb-4 text-4xl font-black tracking-tight md:text-5xl">
        Ad Tracking Opt-Out
      </h1>
      <div class="flex flex-wrap gap-6 text-sm text-foreground/60">
        <span>Last Updated: {lastUpdated}</span>
      </div>
    </div>

    <div
      class="mb-10 border border-primary bg-primary/5 p-6 shadow-xl backdrop-blur-sm"
    >
      <p class="text-sm leading-relaxed text-foreground">
        <strong class="text-foreground">Plain-English Summary:</strong> We use analytics
        tools to measure page visits and site performance. This page lets you turn
        off the extra custom ad and conversion events we send from this browser, such
        as product views, checkout clicks, and purchase or subscription success events.
        The preference is stored locally on this device, so it does not follow you
        across other browsers or devices.
      </p>
    </div>

    <section
      class="mb-10 border border-border bg-background/80 p-6 shadow-xl backdrop-blur-sm md:p-8"
      aria-labelledby="tracking-preference-heading"
    >
      <p
        class="mb-3 text-xs font-semibold tracking-[0.2em] text-primary uppercase"
      >
        Current Status
      </p>
      <h2
        id="tracking-preference-heading"
        data-tracking-status
        class="mb-4 text-2xl font-black tracking-tight text-foreground md:text-3xl"
        aria-live="polite"
      >
        Checking tracking preference...
      </h2>
      <p
        data-tracking-detail
        class="mb-6 text-sm leading-relaxed text-foreground/75"
      >
        Your browser preference will appear here after the page loads.
      </p>

      <div class="flex flex-col gap-3 sm:flex-row">
        <button
          type="button"
          data-disable-tracking
          class="inline-flex min-h-12 items-center justify-center gap-2 border border-primary bg-primary px-5 py-3 text-sm font-black text-primary-foreground shadow-xl transition-colors hover:bg-primary/90 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:outline-none"
          aria-pressed="false"
        >
          <ShieldOff className="h-4 w-4" aria-hidden="true" />
          Disable Custom Event Tracking
        </button>
        <button
          type="button"
          data-enable-tracking
          class="inline-flex min-h-12 items-center justify-center gap-2 border border-border bg-background/80 px-5 py-3 text-sm font-black text-foreground shadow-xl transition-colors hover:border-primary/50 hover:text-primary focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:outline-none"
          aria-pressed="false"
        >
          <ShieldCheck className="h-4 w-4" aria-hidden="true" />
          Enable Custom Event Tracking
        </button>
      </div>
    </section>

    <div class="space-y-8 text-foreground">
      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          What This Controls
        </h2>
        <p class="mb-4 leading-relaxed">
          When ad tracking is disabled, this browser stops sending our custom
          Zaraz ecommerce and advertising events. These events include selected
          product views, checkout-started events, and purchase or subscription
          success events.
        </p>
        <p class="leading-relaxed">
          We may still measure basic page visits and site performance. Essential
          site features, security, checkout routing, and saved display
          preferences can also continue to work because they are not part of
          this ad tracking preference.
        </p>
      </section>

      <section>
        <h2 class="mb-4 text-2xl font-black text-foreground">
          Browser-Specific Preference
        </h2>
        <p class="leading-relaxed">
          This choice is saved in this browser's local storage as
          <code
            class="border border-border bg-card px-1.5 py-0.5 text-sm text-primary"
            >ad_tracking_opt_out</code
          >. Clearing site data, using another browser, or using another device
          may reset the preference.
        </p>
      </section>
    </div>

    <div class="mt-16 border-t border-border pt-8">
      <p class="mb-4 text-sm font-bold text-foreground">All Policies</p>
      <div class="flex flex-wrap gap-4 text-sm">
        {
          policyLinks.map((policy) => (
            <a
              href={policy.href}
              class="text-primary underline underline-offset-2"
            >
              {policy.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <script is:inline>
    ;(() => {
      const storageKey = "ad_tracking_opt_out"
      const status = document.querySelector("[data-tracking-status]")
      const detail = document.querySelector("[data-tracking-detail]")
      const disableButton = document.querySelector("[data-disable-tracking]")
      const enableButton = document.querySelector("[data-enable-tracking]")
      let storageAvailable = true

      const getPreference = () => {
        try {
          storageAvailable = true
          return localStorage.getItem(storageKey) === "true"
        } catch {
          storageAvailable = false
          return false
        }
      }

      const setPreference = (disabled) => {
        try {
          if (disabled) {
            localStorage.setItem(storageKey, "true")
          } else {
            localStorage.removeItem(storageKey)
          }
          storageAvailable = true
        } catch {
          storageAvailable = false
        }

        render()
      }

      const setText = (element, text) => {
        if (element) element.textContent = text
      }

      const render = () => {
        const disabled = getPreference()

        if (!storageAvailable) {
          setText(status, "Tracking preference storage is unavailable.")
          setText(
            detail,
            "This browser is currently blocking local storage, so this page cannot save an ad tracking preference."
          )
          disableButton?.setAttribute("aria-pressed", "false")
          enableButton?.setAttribute("aria-pressed", "false")
          return
        }

        setText(
          status,
          disabled
            ? "Custom ad event tracking is disabled on this browser."
            : "Custom ad event tracking is currently enabled."
        )
        setText(
          detail,
          disabled
            ? "This browser will not send our custom product-view, checkout, purchase, or subscription tracking events while it keeps this saved preference."
            : "This browser can currently send our custom product-view, checkout, purchase, and subscription tracking events."
        )
        disableButton?.setAttribute("aria-pressed", String(disabled))
        enableButton?.setAttribute("aria-pressed", String(!disabled))
      }

      disableButton?.addEventListener("click", () => setPreference(true))
      enableButton?.addEventListener("click", () => setPreference(false))

      render()
    })()
  </script>
</Layout>

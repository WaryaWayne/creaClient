---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import type { BreadcrumbList, ItemList, WebPage, WithContext } from "schema-dts"
import { routes } from "@/lib/routes"
import { getContactEmail, siteConfig } from "@/lib/site-config"

const lastUpdated = "January 15, 2025"
const contactEmail = getContactEmail()
const pageTitle = `Policies & Legal | ${siteConfig.name}`
const pageDescription = `Browse all legal policies for ${siteConfig.name}, including terms of service, privacy, cookies, ad tracking opt-out, refunds, disclaimers, and acceptable use.`
const pageUrl = routes.google.policies.Index
const siteUrl = Astro.site ?? new URL(Astro.url.origin)
const canonicalUrl = new URL(pageUrl, siteUrl).toString()
const itemListId = `${canonicalUrl}#itemlist`
const toAbsoluteUrl = (path: string) => new URL(path, siteUrl).toString()

const policies = [
  {
    eyebrow: "Core Terms",
    title: "Terms of Service",
    href: routes.google.policies.TermsOfService,
    description:
      "The main agreement covering use of the site, service scope, billing, account access, liability limits, and cancellations.",
  },
  {
    eyebrow: "Data & Privacy",
    title: "Privacy Policy",
    href: routes.google.policies.Privacy,
    description:
      "Explains what information we collect, how we use it, how long we retain it, and the choices you have over your data.",
  },
  {
    eyebrow: "Tracking",
    title: "Cookie Policy",
    href: routes.google.policies.Cookies,
    description:
      "Breaks down the cookies and tracking technologies used on the site, why they exist, and how you can control them.",
  },
  {
    eyebrow: "Tracking Choice",
    title: "Ad Tracking Opt-Out",
    href: routes.google.policies.TrackingOptOut,
    description:
      "Lets this browser disable or re-enable non-essential advertising and analytics tracking without a banner.",
  },
  {
    eyebrow: "Billing",
    title: "Refund Policy",
    href: routes.google.policies.Refunds,
    description:
      "Covers cancellations, when refunds are available, when they are not, and how refund requests are reviewed.",
  },
  {
    eyebrow: "Limits & Claims",
    title: "Disclaimer",
    href: routes.google.policies.Disclaimer,
    description:
      "Clarifies that we are not Google, do not guarantee ad results, and provide website content for general information only.",
  },
  {
    eyebrow: "Platform Conduct",
    title: "Acceptable Use Policy",
    href: routes.google.policies.AcceptableUse,
    description:
      "Defines the rules for using our website and services, including prohibited conduct and compliance expectations.",
  },
]

const breadcrumbSchema: WithContext<BreadcrumbList> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  name: "Policies breadcrumb",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Google",
      item: toAbsoluteUrl(import.meta.env.BASE_URL),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Policies",
      item: canonicalUrl,
    },
  ],
}

const webPageSchema: WithContext<WebPage> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  breadcrumb: {
    "@id": `${canonicalUrl}#breadcrumb`,
  },
}

const itemListSchema: WithContext<ItemList> = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": itemListId,
  name: "2To6X legal policies",
  url: canonicalUrl,
  itemListElement: policies.map((policy, index) => {
    const policyUrl = toAbsoluteUrl(policy.href)

    return {
      "@type": "ListItem",
      position: index + 1,
      name: policy.title,
      url: policyUrl,
      description: policy.description,
    }
  }),
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogType="website"
  ogUrl={pageUrl}
  ogDescription={pageDescription}
  canonical={pageUrl}
  schema={[webPageSchema, itemListSchema, breadcrumbSchema]}
>
  <div class="mx-auto max-w-5xl px-4 py-8">
    <PathBreadcrumb className="mb-4" location={Astro.url.pathname} />

    <div class="mb-12 border-b border-border pb-10 text-center">
      <div
        class="mb-4 inline-block border border-primary/30 bg-primary/10 px-4 py-1.5 text-xs font-semibold tracking-widest text-primary uppercase"
      >
        Legal
      </div>
      <h1 class="mb-4 text-4xl font-black tracking-tight md:text-5xl">
        Policies & Legal
      </h1>
      <p
        class="mx-auto max-w-2xl text-base leading-relaxed text-foreground/75 md:text-lg"
      >
        Every legal page in one place. If you need the fine print on billing,
        privacy, cookies, account access, or how the site can be used, start
        here.
      </p>
      <div
        class="mt-6 flex flex-wrap items-center justify-center gap-6 text-sm text-foreground/60"
      >
        <span>Last Updated: {lastUpdated}</span>
        <span>{policies.length} active policy pages</span>
      </div>
    </div>

    <div
      class="mb-12 border border-primary/20 bg-primary/5 p-6 text-center shadow-xl backdrop-blur-sm"
    >
      <p class="text-sm leading-relaxed text-foreground">
        <strong class="text-foreground">Plain-English Summary:</strong> This is the
        central legal hub for {siteConfig.name}. The cards below take you
        straight to the policy you need, whether you are checking our service
        terms, reviewing privacy practices, or looking for refund rules before
        buying.
      </p>
    </div>

    <div class="mx-auto grid max-w-4xl gap-5 md:grid-cols-2">
      {
        policies.map(({ eyebrow, title, href, description }) => (
          <a
            href={href}
            class="group flex min-h-[220px] flex-col justify-between border border-border bg-background/80 p-6 text-left shadow-xl backdrop-blur-sm transition-colors hover:border-primary/40 hover:bg-primary/5 hover:backdrop-blur-sm"
          >
            <div>
              <p class="mb-4 text-xs font-semibold tracking-[0.2em] text-primary uppercase">
                {eyebrow}
              </p>
              <h2 class="mb-3 text-2xl font-black tracking-tight text-foreground transition-colors group-hover:text-primary">
                {title}
              </h2>
              <p class="text-sm leading-relaxed text-foreground/75">
                {description}
              </p>
            </div>

            <div class="mt-8 flex items-center justify-between border-t border-border pt-4 text-sm font-semibold text-foreground">
              <span>View policy</span>
              <span class="text-primary transition-transform group-hover:translate-x-1">
                -&gt;
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <div
      class="mx-auto mt-16 max-w-4xl border border-border bg-background/60 p-6 shadow-xl backdrop-blur-sm"
    >
      <p
        class="mb-2 text-sm font-black tracking-widest text-foreground uppercase"
      >
        Need Something Specific?
      </p>
      <p class="text-sm leading-relaxed text-foreground/75">
        If you are not sure which page answers your question, start with the
        <a
          href={routes.google.policies.TermsOfService}
          class="text-primary underline underline-offset-2"
        >
          Terms of Service
        </a>
        . For privacy questions, contact
        <a
          href={`mailto:${contactEmail}`}
          class="text-primary underline underline-offset-2"
        >
          {contactEmail}
        </a>
        .
      </p>
    </div>
  </div>
</Layout>

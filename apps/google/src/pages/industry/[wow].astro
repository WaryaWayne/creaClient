---
import Layout from "@/layouts/main.astro"
import PathBreadcrumb from "@/components/PathBreadcrumb"
import { serviceTypes, getServiceBySlug } from "@/data/service-types"
import { CTAButton } from "@/components/CTAButton"
import BeforeAfter from "@/components/BeforeAfter.astro"
import { Card, CardContent } from "@workspace/ui/components/card"
import { getSchemaEntityModel, sharedServiceArea } from "@/lib/schema"
import { routes } from "@/lib/routes"
import type { BreadcrumbList, Service, WebPage, WithContext } from "schema-dts"

export function getStaticPaths() {
  return serviceTypes.map((s) => ({ params: { wow: s.slug } }))
}

const { wow } = Astro.params
const service = getServiceBySlug(wow)

if (!service) {
  return Astro.redirect("/404")
}

const {
  name,
  industry,
  tagline,
  headline,
  subheadline,
  urgencyTrigger,
  painPoints,
  badAd,
  goodAd,
  stats,
} = service

const adNoun = service.adNoun ?? `${name} Ads`
const adRewriteNoun = adNoun.replace(/ Ads$/, " Ad")

type PriceAsset = {
  title: string
  price: string
  description: string
}

const industryPriceAssets: Record<string, PriceAsset[]> = {
  plumbers: [
    {
      title: "Drain Unblocking",
      price: "$89",
      description: "Clear blocked drains fast.",
    },
    {
      title: "Leak Detection",
      price: "$129",
      description: "Find hidden leaks before damage spreads.",
    },
    {
      title: "Hot Water System",
      price: "$349",
      description: "Install or replace any hot water unit.",
    },
  ],
  "tow-trucks": [
    {
      title: "Local Tow",
      price: "$95",
      description: "Fast city towing with live ETA.",
    },
    {
      title: "Emergency Recovery",
      price: "$149",
      description: "Roadside rescue when you're stuck now.",
    },
    {
      title: "Highway Winch-Out",
      price: "$249",
      description: "Safe recovery from ditch or shoulder.",
    },
  ],
  dentists: [
    {
      title: "Emergency Exam",
      price: "$79",
      description: "New-patient emergency consult today.",
    },
    {
      title: "Tooth Extraction",

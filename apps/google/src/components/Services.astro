---
import { Card, CardContent } from "@workspace/ui/components/card"
import { CTAButton } from "@/components/CTAButton"
import { routes } from "@/lib/routes"

const services = [
  {
    number: "01",
    title: "Google Ads Audit",
    description:
      "We review where your budget is going and identify low-intent keywords, mismatched match types, Quality Score gaps, and low-value search terms. You get a full written report with every problem identified and every fix explained.",
    includes: [
      "Search term analysis",
      "Keyword match type review",
      "Quality Score audit",
      "Competitor benchmarking",
      "Full fix-it report",
    ],
  },
  {
    number: "02",
    title: "Ad Copy Rewrite",
    description:
      "We replace underperforming ad copy with clearer, more differentiated messaging. Benefit-first headlines. Specific offers. Urgency that doesn't feel fake. A message that makes you stand out from every other ad on the page.",
    includes: [
      "3 headline variations per ad group",
      "Description copy",
      "Call-to-action optimization",
      "Ad extension copywriting",
      "Competitor differentiation",
    ],
  },
  {
    number: "03",
    title: "Full Campaign Setup",
    description:
      "Starting from scratch? Start with a clean campaign structure from day one. We build your entire Google Ads campaign from the ground up, the right way: tight keyword groups, smart bidding, conversion tracking that actually works.",
    includes: [
      "Keyword research & mapping",
      "Campaign & ad group structure",
      "Conversion tracking setup",
      "Negative keyword list",
      "Bidding strategy configuration",
    ],
  },
  {
    number: "04",
    title: "Ongoing Management",
    description:
      'Google Ads isn\'t "set it and forget it." Search terms change, competitors adjust, seasons shift. We monitor your campaigns every week / month, pause or refine underperforming assets, scale what is, and keep your cost-per-lead dropping. You run your business. We run your ads.',
    includes: [
      "Monthly optimization calls",
      "Search term harvesting",
      "Bid adjustments",
      "A/B testing",
      "Monthly performance report",
    ],
  },
]
---

<section class="px-4 py-12" id="services">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 text-center">
      <p class="mb-3 text-sm font-bold tracking-widest text-primary uppercase">
        What We Do
      </p>
      <h2 class="text-4xl font-black md:text-5xl">
        Four Ways We Make Your
        <br />
        <span class="text-primary">Google Ads Actually Work</span>
      </h2>
    </div>
    <div class="mb-12 grid grid-cols-1 gap-6 lg:grid-cols-2">
      {
        services.map(({ number, title, description, includes }) => (
          <Card className="border-border shadow-xl gap-0 py-0 ring-0 group hover:border-primary/40 transition-all">
            <CardContent className="p-8">
              <div class="mb-5 flex items-start gap-4">
                  <span class="text-5xl leading-none font-black text-primary/80">
                  {number}
                </span>
                <h3 class="mt-1 text-2xl font-black text-foreground transition-colors group-hover:text-primary">
                  {title}
                </h3>
              </div>
              <p class="mb-6 leading-relaxed text-foreground">{description}</p>
              <ul class="space-y-2">
                {includes.map((item) => (
                  <li class="flex items-center gap-3 text-sm text-foreground">
                    <span class="h-1.5 w-1.5 shrink-0 bg-primary" />
                    {item}
                  </li>
                ))}
              </ul>
            </CardContent>
          </Card>
        ))
      }
    </div>
    <div
      class="mx-auto max-w-2xl border border-primary/30 bg-primary/5 backdrop-blur-sm p-6 text-center"
    >
      <p class="mb-2 text-xs font-bold tracking-widest text-primary uppercase">
        Choose Your Starting Point
      </p>
      <h3 class="mb-2 text-2xl font-black text-foreground">
        Compare the packages before you buy.
      </h3>
      <p class="mx-auto mb-5 max-w-xl text-sm leading-relaxed text-foreground">
        Start with the audit if the account needs cleanup, or pick the profile
        and weekly options if you already know the next move.
      </p>
      <CTAButton
        variant="default"
        href={routes.google.home + "#offer"}
        target="_self"
      >
        Compare Offers
      </CTAButton>
    </div>
  </div>
</section>

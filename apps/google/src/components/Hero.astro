---
import { CTAButton } from "@/components/CTAButton"
import { PaymentCTA } from "@/components/PaymentCTA"
import { routes } from "@/lib/routes"
import type { ZarazOfferKey } from "@/lib/zaraz"

type HeroCTA = {
  label: string
  href: string
  target?: "_self" | "_blank" | "_parent" | "_top"
  variant?:
    | "default"
    | "outline"
    | "secondary"
    | "ghost"
    | "destructive"
    | "link"
    | null
  note?: string
  paymentOfferKey?: ZarazOfferKey
}

interface Props {
  id?: string
  tagline?: string
  headline?: string
  subheadline?: string | string[]
  subheadlineHtml?: string | string[]
  ctas?: HeroCTA[]
  trustPills?: string[]
}

const {
  id,
  tagline = "Google Ads Optimization",
  headline = `Your Google Ads Are<br /><span class="text-primary">Wasting Your Budget.</span><br />We'll Fix That Fast.`,
  subheadline = "Most local businesses throw $500 to $3,000 / month at Google Ads and get almost nothing back. Bad keywords. Generic copy. Zero strategy. Every audit covers campaigns, copy, keywords, bids, and negatives.",
  subheadlineHtml,
  ctas = [
    {
      label: "Start With an Audit",
      href: routes.google.services.AdsAudit,
      target: "_self",
      variant: "default",
    },
    {
      label: "See the Process",
      href: routes.google.home + "#how-it-works",
      target: "_self",
      variant: "outline",
    },
  ],
  trustPills = [
    "No long-term contracts",
    "Full account audit",
    "One-time $300 project fee",
  ],
} = Astro.props as Props

const subheadlineLines = Array.isArray(subheadline)
  ? subheadline
  : [subheadline]
const subheadlineHtmlLines = subheadlineHtml
  ? Array.isArray(subheadlineHtml)
    ? subheadlineHtml
    : [subheadlineHtml]
  : null
const ctaNote = ctas.find((cta) => cta.note)?.note
const turnstileSiteKey = import.meta.env.TURNSTILE_SITE_KEY
---

<section
  id={id}
  class={`relative flex min-h-screen items-center justify-center overflow-hidden px-4 py-12 ${id ? "scroll-mt-24" : ""}`}
>
  <div
    class="pointer-events-none absolute top-0 left-1/2 h-[400px] w-[800px] -translate-x-1/2 bg-primary opacity-5 blur-[120px]"
  >
  </div>

  <div class="relative mx-auto max-w-5xl text-center">
    <div
      class="mb-6 inline-block border border-primary/30 bg-primary/10 px-4 py-1.5 text-sm font-semibold tracking-widest text-primary uppercase"
    >
      {tagline}
    </div>

    <h1
      class="mb-6 text-5xl leading-[1.0] font-black tracking-tight md:text-7xl"
      set:html={headline}
    />

    {
      subheadlineHtmlLines
        ? subheadlineHtmlLines.map((line, index) => (
            <p
              class={`mx-auto max-w-3xl text-foreground ${
                index === 0
                  ? "mb-4 text-xl leading-relaxed md:text-2xl"
                  : "mb-10 text-base leading-relaxed md:text-lg"
              }`}
              set:html={line}
            />
          ))
        : subheadlineLines.map((line, index) => (
            <p
              class={`mx-auto max-w-3xl text-foreground ${
                index === 0
                  ? "mb-4 text-xl leading-relaxed md:text-2xl"
                  : "mb-10 text-base leading-relaxed md:text-lg"
              }`}
            >
              {line}
            </p>
          ))
    }

    {
      ctas.length > 0 && (
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          {ctas.map(
            ({
              label,
              href,
              target = "_blank",
              variant = "default",
              paymentOfferKey,
            }) =>
              paymentOfferKey ? (
                <PaymentCTA
                  client:load
                  variant={variant}
                  href={href}
                  target={target}
                  offerKey={paymentOfferKey}
                  turnstileSiteKey={turnstileSiteKey}
                >
                  {label}
                </PaymentCTA>
              ) : (
                <CTAButton variant={variant} href={href} target={target}>
                  {label}
                </CTAButton>
              )
          )}
        </div>
      )
    }

    {ctaNote && <p class="mt-4 text-xs text-foreground">{ctaNote}</p>}

    <slot name="secondary-cta" />

    {
      trustPills.length > 0 && (
        <div class="mt-12 flex flex-wrap justify-center gap-8 text-sm text-foreground">
          {trustPills.map((pill) => (
            <span class="flex items-center gap-2">
              <span class="inline-block h-2 w-2 rounded-full bg-primary" />
              {pill}
            </span>
          ))}
        </div>
      )
    }
  </div>
</section>

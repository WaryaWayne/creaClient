---
import { Card, CardContent, CardFooter } from "@workspace/ui/components/card"
import { CTAButton } from "@/components/CTAButton"
import { PaymentCTA } from "@/components/PaymentCTA"
import GoogleLogo from "./GoogleLogo.svg"
import type { ZarazOfferKey } from "@/lib/zaraz"

interface Stat {
  number: string
  label: string
  sublabel: string
}

interface Testimonial {
  quote: string
  name: string
  business: string
}

interface Props {
  id?: string
  stats?: Stat[]
  testimonials?: Testimonial[]
  eyebrow?: string
  heading?: string
  subheading?: string
  showTestimonials?: boolean
  cta?: {
    label?: string
    buttonLabel?: string
    href: string
    target?: string
    eyebrow?: string
    heading?: string
    subheadline?: string
    note?: string
    paymentOfferKey?: ZarazOfferKey
  }
}

const defaultStats: Stat[] = [
  {
    number: "5h",
    label: "Spent per audit",
    sublabel: "Manual review, not a checklist skim",
  },
  {
    number: "5,000",
    label: "Largest negative list",
    sublabel: "Built for one client account",
  },
  {
    number: "100%",
    label: "Competitor checks",
    sublabel: "Every audit reviews rival-name spend",
  },
  {
    number: "6+",
    label: "Ad assets added",
    sublabel: "Phone, WhatsApp, logo, links, callouts, pricing",
  },
]

export const defaultTestimonials: Testimonial[] = [
  {
    quote: "He helped me with my family’s business, 10/10",
    name: "Amani H.",
    business: "Towing company",
  },
  {
    quote:
      "smart guy that helped me save a lot on inefficient ads i was losing money on",
    name: "Abdirashid M.",
    business: "Moving company",
  },
  {
    quote:
      "We had a great experience working with your team. They created a professional website for our business and made the process smooth from start to finish. Communication was clear, the work was completed with care, and the final result gave Prime Capital Logistics a stronger online presence. Highly recommended.",
    name: "Prime C.",
    business: "Logistics company",
  },
]

const {
  id = "social-proof",
  stats = defaultStats,
  testimonials = defaultTestimonials,
  eyebrow = "Built For Cleaner Google Ads",
  heading = "The Numbers Don't Lie.",
  // The heading above is causing issues when it combines with a longer subheading.
  subheading,
  showTestimonials = true,
  cta,
} = Astro.props
const turnstileSiteKey = import.meta.env.TURNSTILE_SITE_KEY
---

<section id={id} class="scroll-mt-24 px-4 py-20">
  <div class="mx-auto max-w-6xl">
    <div class="mb-14 text-center">
      <p class="mb-3 text-sm font-bold tracking-widest text-primary uppercase">
        {eyebrow}
      </p>
      <h2 class="text-4xl font-black md:text-5xl">
        {heading}
        {
          subheading && (
            <>
              <br />
              <span class="text-foreground">{subheading}</span>
            </>
          )
        }
      </h2>
    </div>

    <!-- Stats -->
    <div class="mb-14 grid grid-cols-2 gap-4 lg:grid-cols-4">
      {
        stats.map(({ number, label, sublabel }) => (
          <Card className="border-border shadow-xl text-center py-6 gap-0 ring-0">
            <CardContent className="px-6">
              <p class="mb-1 text-4xl font-black text-primary md:text-5xl">
                {number}
              </p>
              <p class="mb-1 text-sm font-bold text-foreground">{label}</p>
              <p class="text-xs text-foreground">{sublabel}</p>
            </CardContent>
          </Card>
        ))
      }
    </div>

    <!-- Testimonials -->
    {
      showTestimonials && (
        <div class="mb-12 grid grid-cols-1 gap-6 md:grid-cols-3">
          {testimonials.map(({ quote, name }) => (
            // business
            <Card className="border-border shadow-xl gap-0 py-0 ring-0">
              <CardContent className="p-6 flex-1">
                <blockquote class="text-sm leading-relaxed text-foreground">
                  {quote}
                </blockquote>
              </CardContent>
              <CardFooter className="flex justify-between">
                <div>
                  <p class="text-sm font-black text-foreground">{name}</p>
                  {/* <p className="text-xs text-foreground">{business}</p> */}
                </div>

                <div class="flex items-end">
                  <GoogleLogo class="size-5 shrink-0" aria-hidden="true" />
                </div>
              </CardFooter>
            </Card>
          ))}
        </div>
      )
    }

    <p class="text-center text-xs text-foreground">
      * Results vary based on industry, budget, and market competition. These
      are real client outcomes, not guarantees.
    </p>

    {
      cta && (
        <div class="mx-auto mt-8 max-w-2xl border border-primary/30 bg-primary/5 p-6 text-center backdrop-blur-sm">
          {cta.eyebrow && (
            <p class="mb-2 text-xs font-bold tracking-widest text-primary uppercase">
              {cta.eyebrow}
            </p>
          )}
          {cta.heading && (
            <h3 class="mb-2 text-2xl font-black text-foreground">
              {cta.heading}
            </h3>
          )}
          {cta.subheadline && (
            <p class="mx-auto mb-5 max-w-xl text-sm leading-relaxed text-foreground">
              {cta.subheadline}
            </p>
          )}
          {cta.paymentOfferKey ? (
            <PaymentCTA
              client:load
              variant="default"
              href={cta.href}
              target={cta.target ?? "_self"}
              offerKey={cta.paymentOfferKey}
              turnstileSiteKey={turnstileSiteKey}
            >
              {cta.buttonLabel ?? cta.label}
            </PaymentCTA>
          ) : (
            <CTAButton
              variant="default"
              href={cta.href}
              target={cta.target ?? "_self"}
            >
              {cta.buttonLabel ?? cta.label}
            </CTAButton>
          )}
          {cta.note && <p class="mt-3 text-xs text-foreground">{cta.note}</p>}
        </div>
      )
    }
  </div>
</section>

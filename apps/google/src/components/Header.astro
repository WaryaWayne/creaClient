---
import { ArrowRight } from "lucide-react"
import {
  industriesOverviewHref,
  orderIndustriesForNav,
  primaryCtaHref,
  primaryNavLinks,
  serviceLinks,
  servicesOverviewHref,
} from "@/lib/site-nav"
import { serviceTypes } from "@/data/service-types"
import { MobileNav } from "./MobileNav.tsx"
import { CTAButton } from "./CTAButton"
import { ModeToggle } from "./ModeToggle"
import { ButtonGroup } from "@workspace/ui/components/button-group"
import Logo from "@/assets/logo.svg"
import { routes } from "@/lib/routes"

const normalizePath = (value: string) => {
  if (value === "/") {
    return value
  }

  return value.replace(/\/+$/, "")
}

const currentPath = normalizePath(Astro.url.pathname)
const isCurrentLink = (href: string) => {
  const path = href.split("#")[0] || "/"
  return normalizePath(path) === currentPath
}
const navIndustries = orderIndustriesForNav(serviceTypes)
---

<header
  class="sticky top-0 z-50 mx-auto max-w-[1000px] bg-transparent shadow-lg backdrop-blur-2xl"
>
  <!-- Main navigation -->
  <nav
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a
      href={import.meta.env.BASE_URL}
      class="flex items-center"
      aria-label="2To6X home"
    >
      <Logo
        class="h-10 w-auto transition-transform duration-200 hover:scale-105"
      />
    </a>

    <!-- Desktop nav links -->
    <div
      class="hidden items-center gap-6 text-sm font-medium text-foreground lg:flex"
    >
      {
        primaryNavLinks
          .filter((link) => link.href !== servicesOverviewHref)
          .map((link) => (
            <a
              href={link.href}
              aria-current={isCurrentLink(link.href) ? "page" : undefined}
              class:list={[
                "transition-colors hover:text-primary",
                isCurrentLink(link.href) && "text-primary",
              ]}
            >
              {link.label}
            </a>
          ))
      }

      <!-- Services dropdown -->
      <div class="group relative">
        <button
          class="flex items-center gap-1 py-4 transition-colors hover:text-primary"
          aria-expanded="false"
          aria-haspopup="true"
        >
          Services
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 transition-transform group-hover:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div
          class="invisible absolute top-full left-1/2 z-50 w-[520px] -translate-x-1/2 border border-border bg-background p-2 opacity-0 shadow-xl transition-all duration-200 group-hover:visible group-hover:opacity-100"
        >
          <div class="grid grid-cols-1 gap-2">
            {
              serviceLinks.map((service) => (
                <a
                  href={service.href}
                  class="border border-transparent px-4 py-3 text-sm text-foreground transition-colors hover:border-primary/20 hover:bg-primary/5 hover:backdrop-blur-sm"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="font-semibold text-foreground">
                        {service.label}
                      </p>
                      <p class="mt-1 text-xs leading-relaxed text-muted-foreground">
                        {service.description}
                      </p>
                    </div>
                    <span class="shrink-0 text-xs font-semibold text-primary">
                      {service.price}
                    </span>
                  </div>
                </a>
              ))
            }
          </div>
          <div class="mt-2 border-t border-border px-2 pt-2">
            <a
              href={servicesOverviewHref}
              class="flex items-center justify-center gap-1 py-2 text-xs font-semibold text-primary transition-colors hover:text-primary/80"
            >
              Compare All Services <ArrowRight className="h-3.5 w-3.5" />
            </a>
          </div>
        </div>
      </div>

      <!-- Industries dropdown -->
      <div class="group relative">
        <button
          class="flex items-center gap-1 py-4 transition-colors hover:text-primary"
          aria-expanded="false"
          aria-haspopup="true"
        >
          Industries
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 transition-transform group-hover:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div
          class="invisible absolute top-full left-1/2 z-50 w-[560px] -translate-x-1/2 border border-border bg-background p-2 opacity-0 shadow-xl transition-all duration-200 group-hover:visible group-hover:opacity-100"
        >
          <p
            class="mb-3 px-2 pt-2 text-xs font-bold tracking-widest text-primary uppercase"
          >
            See industry-specific ad examples & fixes
          </p>
          <div class="grid auto-rows-fr grid-cols-3 gap-1 px-2 pb-2">
            {
              navIndustries.map((s) => (
                <a
                  href={`${routes.google.industry.Index}/${s.slug}`}
                  class="flex h-full min-h-[3.25rem] items-center justify-center border border-border px-2.5 py-1.5 text-center text-sm text-foreground transition-colors hover:bg-primary/5 hover:text-primary hover:backdrop-blur-sm"
                >
                  <span class="leading-tight font-medium">{s.name}</span>
                </a>
              ))
            }
          </div>
          <div class="mt-2 border-t border-border px-2 pt-2">
            <a
              href={industriesOverviewHref}
              class="flex items-center justify-center gap-1 py-2 text-xs font-semibold text-primary transition-colors hover:text-primary/80"
            >
              Compare All Industries <ArrowRight className="h-3.5 w-3.5" />
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA button -->
    <ButtonGroup className="hidden lg:flex lg:items-center lg:gap-2">
      <ModeToggle client:media="(min-width: 1024px)" />
      <CTAButton variant={"default"} target="_self" href={primaryCtaHref}>
        Get Started
      </CTAButton>
    </ButtonGroup>

    <!-- Mobile nav with Sheet component -->
    <div class="lg:hidden">
      <ButtonGroup className="flex items-center gap-2">
        <ModeToggle client:media="(max-width: 1023px)" />
        <MobileNav client:media="(max-width: 1023px)" />
      </ButtonGroup>
    </div>
  </nav>
</header>

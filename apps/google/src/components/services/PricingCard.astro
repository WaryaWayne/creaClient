---
import { Card, CardContent } from "@workspace/ui/components/card"
import { CTAButton } from "@/components/CTAButton"
import { PaymentCTA } from "@/components/PaymentCTA"
import type { ZarazOfferKey } from "@/lib/zaraz"

interface Props {
  variant?: "hero" | "plan"
  itemLabel?: string
  title?: string
  titleClassName?: string
  price: string
  per?: string
  description: string
  pills?: string[]
  ctaLabel: string
  ctaHref: string
  ctaTarget?: "_blank" | "_self"
  footnote?: string
  cardClassName?: string
  priceClassName?: string
  pillsWrapClassName?: string
  pillClassName?: string
  planName?: string
  planBilling?: string
  highlight?: boolean
  badge?: string
  planCardClassName?: string
  planButtonClassName?: string
  paymentOfferKey?: ZarazOfferKey
}

const {
  variant = "hero",
  itemLabel,
  title,
  titleClassName = "text-foreground text-sm mb-2",
  price,
  per,
  description,
  pills = [],
  ctaLabel,
  ctaHref,
  ctaTarget = "_self",
  footnote,
  cardClassName,
  priceClassName = "text-8xl font-black text-primary",
  pillsWrapClassName = "flex flex-wrap justify-center gap-3 mb-8 text-sm",
  pillClassName = "flex items-center gap-1.5 bg-background border border-border px-4 py-1.5",
  planName,
  planBilling,
  highlight = false,
  badge,
  planCardClassName,
  planButtonClassName,
  paymentOfferKey,
} = Astro.props as Props

const isExternal = ctaTarget === "_blank"
const turnstileSiteKey = import.meta.env.TURNSTILE_SITE_KEY
---

{
  variant === "plan" ? (
    <Card
      className={`relative flex flex-col gap-0 overflow-visible py-0 ring-0 ${highlight ? "border-primary bg-primary/5 backdrop-blur-xs" : "border-border"} ${planCardClassName ?? ""}`.trim()}
    >
      {badge && (
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-3 py-1 text-xs font-black tracking-widest whitespace-nowrap text-foreground uppercase">
          {badge}
        </div>
      )}
      <CardContent className="px-6 py-6 flex flex-col flex-1">
        <p
          class={`mb-4 text-sm font-black tracking-widest uppercase ${highlight ? "text-primary" : "text-foreground"}`}
        >
          {planName}
        </p>
        <div class="mb-1">
          <span
            class={`text-5xl font-black ${highlight ? "text-primary" : "text-foreground"}`}
          >
            {price}
          </span>
          {per && <span class="ml-1 text-sm text-foreground">{per}</span>}
        </div>
        {planBilling && (
          <p class="mb-3 text-xs font-bold text-primary">{planBilling}</p>
        )}
        <p class="mb-6 flex-1 text-xs leading-relaxed text-foreground">
          {description}
        </p>
        {paymentOfferKey ? (
          <PaymentCTA
            client:load
            variant={highlight ? "default" : "outline"}
            href={ctaHref}
            target={ctaTarget}
            offerKey={paymentOfferKey}
            turnstileSiteKey={turnstileSiteKey}
            className={`w-full py-3 text-sm ${planButtonClassName ?? ""}`.trim()}
          >
            {ctaLabel}
          </PaymentCTA>
        ) : (
          <a
            href={ctaHref}
            target={ctaTarget}
            rel={isExternal ? "noopener noreferrer" : undefined}
            class={`block py-3 text-center text-sm font-black tracking-wide uppercase transition hover:brightness-110 ${highlight ? "bg-primary text-foreground" : "border border-border bg-background text-foreground hover:border-primary/50"} ${planButtonClassName ?? ""}`.trim()}
          >
            {ctaLabel}
          </a>
        )}
      </CardContent>
    </Card>
  ) : (
    <div
      class={`relative overflow-hidden border-2 border-primary bg-background p-10 ${cardClassName ?? ""}`.trim()}
    >
      <div class="absolute -top-16 left-1/2 h-32 w-80 -translate-x-1/2 bg-primary opacity-10 blur-[60px]" />
      <div class="relative">
        {(itemLabel || title) && (
          <p class={titleClassName}>{itemLabel ?? title}</p>
        )}
        <div class="mb-2 flex items-baseline justify-center gap-3">
          <span class={priceClassName}>{price}</span>
          {per && <span class="text-sm text-foreground">{per}</span>}
        </div>
        <p class="mb-8 text-foreground">{description}</p>
        {pills.length > 0 && (
          <div class={pillsWrapClassName}>
            {pills.map((item) => (
              <span class={pillClassName}>
                <span class="text-primary">✓</span>
                <span class="text-foreground">{item}</span>
              </span>
            ))}
          </div>
        )}
        {paymentOfferKey ? (
          <PaymentCTA
            client:load
            variant="default"
            target={ctaTarget}
            href={ctaHref}
            offerKey={paymentOfferKey}
            turnstileSiteKey={turnstileSiteKey}
          >
            {ctaLabel}
          </PaymentCTA>
        ) : (
          <CTAButton variant="default" target={ctaTarget} href={ctaHref}>
            {ctaLabel}
          </CTAButton>
        )}
        {footnote && <p class="mt-3 text-xs text-foreground">{footnote}</p>}
      </div>
    </div>
  )
}

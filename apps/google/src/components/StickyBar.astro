---
import { routes } from "@/lib/routes"
import {
  getCompanyPhoneNumber,
  getCompanyPhoneNumberDisplay,
} from "@/lib/site-config"
import { Phone } from "lucide-react"

interface Props {
  /** Text for the primary (right) CTA button. Defaults to "Open Audit Page" */
  primaryText?: string
  /** href for the primary CTA button. Defaults to "/services/ads-audit" */
  primaryHref?: string
  /**
   * Type of the secondary (left) button.
   * - 'phone'  → shows a phone icon + call link (default)
   * - 'cta'    → shows an outline CTA link (e.g. for pricing pages)
   */
  secondaryType?: "phone" | "cta"
  /** Display text for the secondary button */
  secondaryText?: string
  /** href for the secondary button — use a tel: link when secondaryType is 'phone' */
  secondaryHref?: string
}

const companyPhoneNumber = getCompanyPhoneNumber()
const companyPhoneNumberDisplay = getCompanyPhoneNumberDisplay()

const {
  primaryText = "Open Audit Page",
  primaryHref = routes.google.services.AdsAudit,
  secondaryType = "phone",
  secondaryText = companyPhoneNumberDisplay,
  secondaryHref = `tel:${companyPhoneNumber}`,
} = Astro.props
---

<!-- Mobile-only sticky CTA bar -->
<div
  class="fixed right-0 bottom-0 left-0 z-50 flex items-center gap-3 border-t border-border bg-background px-4 pt-4 pb-[calc(1rem+env(safe-area-inset-bottom))] shadow-[0_-4px_24px_rgba(0,0,0,0.6)] lg:hidden"
>
  {
    secondaryType === "phone" ? (
      <a
        href={secondaryHref}
        class="flex flex-1 items-center justify-center gap-2 border border-border bg-background py-3 text-sm font-bold text-foreground"
      >
        <Phone className="h-4 w-4 shrink-0" aria-hidden="true" />
        {secondaryText}
      </a>
    ) : (
      <a
        href={secondaryHref}
        class="flex flex-1 items-center justify-center gap-2 border border-primary py-3 text-sm font-black tracking-wide text-primary uppercase"
      >
        {secondaryText}
      </a>
    )
  }

  <a
    href={primaryHref}
    class="flex flex-1 items-center justify-center gap-2 bg-primary py-3 text-sm font-black tracking-wide text-primary-foreground uppercase"
  >
    {primaryText}
  </a>
</div>

<script is:inline>
  document.body.classList.add("has-mobile-sticky-bar")
</script>

<style is:global>
  @media (max-width: 1023px) {
    body.has-mobile-sticky-bar {
      padding-bottom: calc(6.5rem + env(safe-area-inset-bottom));
    }
  }
</style>

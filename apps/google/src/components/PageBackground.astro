---
// Reusable full-page checkerboard grid background.
// Renders a fixed, pointer-events-none overlay behind all page content.
// Light mode: subtle black grid lines (6% opacity)
// Dark mode:  subtle lime-green grid lines (3% opacity)
---

<div
  aria-hidden="true"
  class="pointer-events-none fixed inset-0 -z-10 bg-[linear-gradient(rgba(0,0,0,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.06)_1px,transparent_1px)] bg-[size:60px_60px] dark:bg-[linear-gradient(rgba(200,230,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(200,230,0,0.03)_1px,transparent_1px)]"
>
</div>
